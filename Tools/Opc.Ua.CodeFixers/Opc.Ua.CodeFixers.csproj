<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IsRoslynComponent>true</IsRoslynComponent>
    <AssemblyName>$(AssemblyPrefix).CodeFixers</AssemblyName>
    <RootNamespace>Opc.Ua.CodeFixers</RootNamespace>
    <Description>OPC UA .NET Standard migration analyzers and code fixers (1.5.378 to 2.0).</Description>
    <!-- RS1007: localizable resources not required for internal analyzer messages.
         RS1038: shipping analyzers + code fixes in one assembly is supported - the
                 NuGet host provides Workspaces in IDE scenarios, and the analyzer
                 itself doesn't reference Workspaces types. -->
    <NoWarn>$(NoWarn);RS1007;RS1038</NoWarn>
  </PropertyGroup>
  <!-- Package as analyzer + code-fix provider -->
  <PropertyGroup>
    <PackageId>$(PackagePrefix).Opc.Ua.CodeFixers</PackageId>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsPackable>false</IsPackable>
    <NoPackageAnalysis>true</NoPackageAnalysis>
    <DevelopmentDependency>true</DevelopmentDependency>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Update="NETStandard.Library" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.CodeFixers.Tests" />
  </ItemGroup>
  <ItemGroup>
    <!-- Pack the build props so consumers wire up help links and configuration. -->
    <None Include="OPCFoundation.Opc.Ua.CodeFixers.props" Visible="false" Pack="true" PackagePath="build" />
    <!-- Roslyn release tracking files. -->
    <AdditionalFiles Include="AnalyzerReleases.Shipped.md" />
    <AdditionalFiles Include="AnalyzerReleases.Unshipped.md" />
  </ItemGroup>
  <!-- Pack the analyzer DLL into the analyzers/dotnet/cs folder so consumers auto-load it. -->
  <Target Name="_AddAnalyzerToPackage">
    <ItemGroup>
      <TfmSpecificPackageFile Include="$(OutputPath)$(AssemblyName).dll" PackagePath="analyzers/dotnet/cs/" />
    </ItemGroup>
  </Target>
  <PropertyGroup>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_AddAnalyzerToPackage</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>
</Project>

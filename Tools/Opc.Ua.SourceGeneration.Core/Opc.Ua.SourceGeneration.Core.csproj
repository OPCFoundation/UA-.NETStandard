<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(LibCoreTargetFrameworks);netstandard2.0</TargetFrameworks>
    <AssemblyName>$(AssemblyPrefix).SourceGeneration.Core</AssemblyName>
    <PackageId>$(PackagePrefix).Opc.Ua.SourceGeneration.Core</PackageId>
    <RootNamespace>Opc.Ua.SourceGeneration</RootNamespace>
    <Description>OPC UA source generation common Library</Description>
    <IsPackable>true</IsPackable>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageLicenseFile></PackageLicenseFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
    <InternalsVisibleTo Include="Opc.Ua.SourceGeneration" />
    <InternalsVisibleTo Include="Opc.Ua.SourceGeneration.Stack" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Design\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="Generators\NodesetGenerator.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.SourceGeneration.Core.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Stack\Opc.Ua.Types\Opc.Ua.Types.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Needed for ReferenceMetadataScanner to read OpcUaModelDependency
         attributes from referenced assemblies via PEReader. Part of the BCL
         on net5+ but needs an explicit package reference on netstandard. -->
    <PackageReference Include="System.Reflection.Metadata" />
  </ItemGroup>
</Project>

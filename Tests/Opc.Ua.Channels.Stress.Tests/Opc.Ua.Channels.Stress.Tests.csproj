<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!--
      Stress/chaos tests rely on modern primitives (Task.Delay TimeProvider
      overloads, RandomNumberGenerator.GetInt32, Math.Clamp,
      ValueTask.CompletedTask, IClientChannelManager.ReconnectAsync(budget))
      that do not exist on net48/net472. Restrict TFMs to the supported set
      so CodeQL and other whole-solution builds do not try to compile this
      project against the legacy frameworks.
    -->
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <RootNamespace>Opc.Ua.Channels.Stress.Tests</RootNamespace>
    <GenerateProgramFile>false</GenerateProgramFile>
    <Nullable>annotations</Nullable>
    <SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
    <NoWarn>$(NoWarn);RCS0056;RCS1166;RCS1174;RCS1229;RCS1047;RCS1077;NUnit2023;NUnit2010;NUnit2045;CA2007;CA2000;CA2016;CA2025;CA5394;CA1861;CS1591</NoWarn>
  </PropertyGroup>
  <PropertyGroup Condition="'$(NetStandardTests)' == 'true'">
    <DefineConstants>$(DefineConstants);NET_STANDARD_TESTS</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="NUnit" />
    <PackageReference Include="NUnit.Console" />
    <PackageReference Include="NUnit.Analyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="NUnit3TestAdapter">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Moq" />
    <PackageReference Include="Microsoft.Bcl.TimeProvider" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" PrivateAssets="all" />
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Common\Main.cs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Client\Opc.Ua.Client.csproj">
      <AdditionalProperties>SuppressTfmSupportBuildWarnings=true</AdditionalProperties>
    </ProjectReference>
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Configuration\Opc.Ua.Configuration.csproj">
      <AdditionalProperties>SuppressTfmSupportBuildWarnings=true</AdditionalProperties>
    </ProjectReference>
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Server\Opc.Ua.Server.csproj">
      <AdditionalProperties>SuppressTfmSupportBuildWarnings=true</AdditionalProperties>
    </ProjectReference>
    <ProjectReference Include="..\..\Applications\Quickstarts.Servers\Quickstarts.Servers.csproj">
      <AdditionalProperties>SuppressTfmSupportBuildWarnings=true</AdditionalProperties>
    </ProjectReference>
    <ProjectReference Include="..\Opc.Ua.Client.TestFramework\Opc.Ua.Client.TestFramework.csproj">
      <AdditionalProperties>SuppressTfmSupportBuildWarnings=true</AdditionalProperties>
    </ProjectReference>
    <ProjectReference Include="..\Opc.Ua.Server.TestFramework\Opc.Ua.Server.TestFramework.csproj">
      <AdditionalProperties>SuppressTfmSupportBuildWarnings=true</AdditionalProperties>
    </ProjectReference>
    <ProjectReference Include="..\Opc.Ua.Test.Common\Opc.Ua.Test.Common.csproj">
      <AdditionalProperties>SuppressTfmSupportBuildWarnings=true</AdditionalProperties>
    </ProjectReference>
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>$(TestsTargetFrameworks)</TargetFrameworks>
    <AssemblyName>Opc.Ua.PubSub.Legacy.Tests</AssemblyName>
    <RootNamespace>Opc.Ua.PubSub.Legacy.Tests</RootNamespace>
    <GenerateProgramFile>false</GenerateProgramFile>
    <!-- Legacy test project deliberately exercises [Obsolete] shim API per
         the "shim_top_level_only" decision. Suppress UA0023 (the
         migration analyzer) and CS0618 (the language obsolete warning) so
         this project can compile and run against the retained shim. -->
    <NoWarn>$(NoWarn);UA0023;CS0618;CS0612</NoWarn>
  </PropertyGroup>
  <PropertyGroup Condition="'$(NetStandardTests)' == 'true'">
    <DefineConstants>$(DefineConstants);NET_STANDARD_TESTS</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="Newtonsoft.Json" />
    <PackageReference Include="NUnit" />
    <PackageReference Include="NUnit.Console" />
    <PackageReference Include="NUnit.Analyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="NUnit3TestAdapter">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Moq" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" PrivateAssets="all" />
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="BenchmarkDotNet" />
    <PackageReference Include="System.Private.Uri" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Common\Main.cs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Libraries\Opc.Ua.PubSub\Opc.Ua.PubSub.csproj" />
    <!-- The legacy 1.04 shim types (UaPubSubApplication, UaNetworkMessage,
         UaPubSubConnection, ...) now live in Opc.Ua.PubSub.Legacy. -->
    <ProjectReference Include="..\..\Libraries\Opc.Ua.PubSub.Legacy\Opc.Ua.PubSub.Legacy.csproj" />
    <ProjectReference Include="..\..\Stack\Opc.Ua.Core\Opc.Ua.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Update="Configuration\SubscriberConfiguration.xml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="Configuration\PublisherConfiguration.xml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Test.Common\Opc.Ua.Test.Common.csproj" />
  </ItemGroup>
</Project>

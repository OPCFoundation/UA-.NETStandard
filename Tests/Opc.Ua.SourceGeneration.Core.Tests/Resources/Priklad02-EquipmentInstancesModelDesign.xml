<opc:ModelDesign
  xmlns:uax="http://opcfoundation.org/UA/2008/02/Types.xsd"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:ua="http://opcfoundation.org/UA/"
  xmlns:et="http://stuba.fei.sk/priklad02/EquipmentTypes"
  xmlns:opc="http://opcfoundation.org/UA/ModelDesign.xsd"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
  xmlns="http://stuba.fei.sk/priklad02/EquipmentInstances"
  TargetNamespace="http://stuba.fei.sk/priklad02/EquipmentInstances"
  TargetXmlNamespace="http://stuba.fei.sk/priklad02/EquipmentInstances"
  TargetVersion="1.01.00"
  TargetPublicationDate="2026-06-11T00:00:00Z">

	<opc:Namespaces>
		<opc:Namespace Name="EquipmentInstance" Prefix="Opc.EI"  XmlPrefix="OpcEI">http://stuba.fei.sk/priklad02/EquipmentInstances</opc:Namespace>
		<opc:Namespace Name="OpcUa" Prefix="Opc.Ua" InternalPrefix="Opc.Ua.Server" XmlNamespace="http://opcfoundation.org/UA/2008/02/Types.xsd" XmlPrefix="OpcUa">http://opcfoundation.org/UA/</opc:Namespace>
		<opc:Namespace Name="EquipmentTypes" Prefix="Opc.ET" InternalPrefix="Opc.Ua.Et.Server" XmlPrefix="OpcET">http://stuba.fei.sk/priklad02/EquipmentTypes</opc:Namespace>
	</opc:Namespaces>

	<!--Definícia inštancie Equipment01-->	
	<opc:Object SymbolicName="Equipment01" TypeDefinition ="et:SimpleEquipmentType" SupportsEvents="true">
		<opc:Description>Zariadenie 01</opc:Description>
		<opc:Children>
			<!--Vlastnosti-->
			<opc:Property SymbolicName="Description" DataType="ua:String" ValueRank="Scalar" AccessLevel="Read">
				<opc:DefaultValue>
					<uax:String>Zariadenie 01</uax:String>
				</opc:DefaultValue>				
			</opc:Property>
			<!--Premenné-->
			<opc:Variable SymbolicName="Input" DataType="ua:Int32" ValueRank="Scalar" AccessLevel="ReadWrite">
				<opc:DefaultValue>
					<uax:Int32>0</uax:Int32>
				</opc:DefaultValue>
			</opc:Variable>
			<opc:Variable SymbolicName="Output" DataType="ua:Int32" ValueRank="Scalar" AccessLevel="Read">
				<opc:DefaultValue>
					<uax:Int32>0</uax:Int32>
				</opc:DefaultValue>
			</opc:Variable>
		</opc:Children>
		<!-- Prepojenie na adresár ObjectsFolder  -->
		<opc:References>
			<opc:Reference IsInverse="true">
				<opc:ReferenceType>ua:Organizes</opc:ReferenceType>
				<opc:TargetId>ua:ObjectsFolder</opc:TargetId>
			</opc:Reference>
		</opc:References>
	</opc:Object>

	<!--Definícia inštancie Equipment02-->
	<opc:Object SymbolicName="Equipment02" TypeDefinition ="et:SimpleEquipmentType" SupportsEvents="true">
		<opc:Description>Zariadenie 02</opc:Description>
		<opc:Children>
			<!--Vlastnosti-->
			<opc:Property SymbolicName="Description" DataType="ua:String" ValueRank="Scalar" AccessLevel="Read">
				<opc:DefaultValue>
					<uax:String>Zariadenie 02</uax:String>
				</opc:DefaultValue>
			</opc:Property>
			<!--Premenné-->
			<opc:Variable SymbolicName="Input" DataType="ua:Int32" ValueRank="Scalar" AccessLevel="ReadWrite">
				<opc:DefaultValue>
					<uax:Int32>0</uax:Int32>
				</opc:DefaultValue>
			</opc:Variable>
			<opc:Variable SymbolicName="Output" DataType="ua:Int32" ValueRank="Scalar" AccessLevel="Read">
				<opc:DefaultValue>
					<uax:Int32>0</uax:Int32>
				</opc:DefaultValue>
			</opc:Variable>
		</opc:Children>
		<!-- Prepojenie na adresár ObjectsFolder  -->
		<opc:References>
			<opc:Reference IsInverse="true">
				<opc:ReferenceType>ua:Organizes</opc:ReferenceType>
				<opc:TargetId>ua:ObjectsFolder</opc:TargetId>
			</opc:Reference>
		</opc:References>
	</opc:Object>	
</opc:ModelDesign>

<opc:ModelDesign
  xmlns:uax="http://opcfoundation.org/UA/2008/02/Types.xsd"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:ua="http://opcfoundation.org/UA/"
  xmlns:wt="http://test.org/UA/CrossModel/Types"
  xmlns:opc="http://opcfoundation.org/UA/ModelDesign.xsd"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
  xmlns="http://test.org/UA/CrossModel/Instances"
  TargetNamespace="http://test.org/UA/CrossModel/Instances"
  TargetXmlNamespace="http://test.org/UA/CrossModel/Instances"
  TargetVersion="1.0.0"
  TargetPublicationDate="2024-01-01T00:00:00Z">

  <opc:Namespaces>
    <opc:Namespace Name="CrossModelInstances" Prefix="CrossModel.Instances" XmlPrefix="CrossModelInstances">http://test.org/UA/CrossModel/Instances</opc:Namespace>
    <opc:Namespace Name="OpcUa" Prefix="Opc.Ua" InternalPrefix="Opc.Ua.Server" XmlNamespace="http://opcfoundation.org/UA/2008/02/Types.xsd" XmlPrefix="OpcUa">http://opcfoundation.org/UA/</opc:Namespace>
    <opc:Namespace Name="CrossModelTypes" Prefix="CrossModel.Types" XmlPrefix="CrossModelTypes">http://test.org/UA/CrossModel/Types</opc:Namespace>
  </opc:Namespaces>

  <!-- Instance whose TypeDefinition lives in the NodeSet2 input. -->
  <opc:Object SymbolicName="Widget1" TypeDefinition="wt:WidgetType" SupportsEvents="false">
    <opc:Description>First widget instance.</opc:Description>
    <opc:References>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>ua:Organizes</opc:ReferenceType>
        <opc:TargetId>ua:ObjectsFolder</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:Object>

</opc:ModelDesign>

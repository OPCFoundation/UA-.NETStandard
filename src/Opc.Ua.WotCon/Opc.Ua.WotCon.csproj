<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).WotCon</AssemblyName>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.WotCon</PackageId>
    <RootNamespace>Opc.Ua.WotCon</RootNamespace>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <Nullable>enable</Nullable>
    <Description>OPC UA WoT Connectivity 1.1 information model — a registry-first revision (additive registry nodes plus the incorporated, deprecated OPC 10100-1 v1.02 surface) in one namespace.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageLicenseFile></PackageLicenseFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Server" />
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Client" />
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Core\Opc.Ua.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\tools\Opc.Ua.SourceGeneration\Opc.Ua.SourceGeneration.csproj">
      <OutputItemType>Analyzer</OutputItemType>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>
  <Import Project="..\..\tools\Opc.Ua.SourceGeneration\OPCFoundation.Opc.Ua.SourceGeneration.props" />
  <PropertyGroup>
    <ModelSourceGeneratorVersion>v105</ModelSourceGeneratorVersion>
    <!-- Model-only assembly: opt out of typed-accessor emission since
         the emitted code references Opc.Ua.Server.Fluent.* which this
         project does not reference. -->
    <ModelSourceGeneratorOmitFluentApi>true</ModelSourceGeneratorOmitFluentApi>
    <ModelSourceGeneratorUseAllowSubtypes>true</ModelSourceGeneratorUseAllowSubtypes>
  </PropertyGroup>
  <ItemGroup>
    <!-- Legacy OPC 10100-1 v1.02 ModelDesign sources are retained under Design
         purely as human-readable documentation of the surface incorporated
         into the combined 1.1 NodeSet below. They are intentionally NOT
         source-generated: the combined NodeSet is the single generation input,
         so the 1.02 model is never generated a second time. -->
    <None Remove="Design\Opc.Ua.XRegistry.NodeSet2.csv" />
    <None Remove="Design\Opc.Ua.XRegistry.NodeSet2.xml" />
    <None Remove="Design\Opc.Ua.WoTCon.NodeSet2.csv" />
    <None Remove="Design\Opc.Ua.WoTCon.NodeSet2.xml" />
  </ItemGroup>
  <ItemGroup>
    <!-- xRegistry abstract registry base model (http://opcfoundation.org/UA/xRegistry/).
         Emitted into the Opc.Ua.XRegistry C# namespace so its RegistryType /
         GroupType / ResourceType constants are available as base types for the
         WoT registry types incorporated in the combined model below. -->
    <AdditionalFiles Include="Design\Opc.Ua.XRegistry.NodeSet2.xml">
      <ModelSourceGeneratorPrefix>Opc.Ua.XRegistry</ModelSourceGeneratorPrefix>
      <ModelSourceGeneratorName>XRegistry</ModelSourceGeneratorName>
      <ModelSourceGeneratorModelUri>http://opcfoundation.org/UA/xRegistry/</ModelSourceGeneratorModelUri>
    </AdditionalFiles>
    <AdditionalFiles Include="Design\Opc.Ua.XRegistry.NodeSet2.csv" />
    <!-- WoT Connectivity 1.1 combined model (http://opcfoundation.org/UA/WoT-Con/).
         One NodeSet in one namespace incorporating the complete published
         OPC 10100-1 v1.02 model (NodeIds 1..172, marked deprecated) plus the
         additive registry nodes (64000+). Emitted into the Opc.Ua.WotCon C#
         namespace with the same prefix / name / model URI the standalone 1.02
         model previously used, so every existing 1.02 generated constant,
         NodeState and proxy — and its exact NodeId — is preserved. -->
    <AdditionalFiles Include="Design\Opc.Ua.WoTCon.NodeSet2.xml">
      <ModelSourceGeneratorPrefix>Opc.Ua.WotCon</ModelSourceGeneratorPrefix>
      <ModelSourceGeneratorName>WotCon</ModelSourceGeneratorName>
      <ModelSourceGeneratorModelUri>http://opcfoundation.org/UA/WoT-Con/</ModelSourceGeneratorModelUri>
    </AdditionalFiles>
    <AdditionalFiles Include="Design\Opc.Ua.WoTCon.NodeSet2.csv" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

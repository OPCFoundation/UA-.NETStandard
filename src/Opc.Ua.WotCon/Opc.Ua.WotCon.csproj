<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).WotCon</AssemblyName>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.WotCon</PackageId>
    <RootNamespace>Opc.Ua.WotCon</RootNamespace>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <Nullable>enable</Nullable>
    <Description>OPC UA WoT Connectivity (OPC 10100-1) information model</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageLicenseFile></PackageLicenseFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Server" />
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Client" />
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Core\Opc.Ua.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\tools\Opc.Ua.SourceGeneration\Opc.Ua.SourceGeneration.csproj">
      <OutputItemType>Analyzer</OutputItemType>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>
  <Import Project="..\..\tools\Opc.Ua.SourceGeneration\OPCFoundation.Opc.Ua.SourceGeneration.props" />
  <PropertyGroup>
    <ModelSourceGeneratorVersion>v105</ModelSourceGeneratorVersion>
    <!-- Model-only assembly: opt out of typed-accessor emission since
         the emitted code references Opc.Ua.Server.Fluent.* which this
         project does not reference. -->
    <ModelSourceGeneratorOmitFluentApi>true</ModelSourceGeneratorOmitFluentApi>
    <ModelSourceGeneratorUseAllowSubtypes>true</ModelSourceGeneratorUseAllowSubtypes>
  </PropertyGroup>
  <ItemGroup>
    <None Remove="Design\WotConnection.csv" />
    <None Remove="Design\WotConnection.xml" />
    <None Remove="Design\Opc.Ua.XRegistry.NodeSet2.csv" />
    <None Remove="Design\Opc.Ua.XRegistry.NodeSet2.xml" />
    <None Remove="Design\Opc.Ua.WoTConV2.NodeSet2.csv" />
    <None Remove="Design\Opc.Ua.WoTConV2.NodeSet2.xml" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="Design\WotConnection.csv" />
    <AdditionalFiles Include="Design\WotConnection.xml" />
    <!-- xRegistry abstract registry base model (http://opcfoundation.org/UA/xRegistry/).
         Emitted into the Opc.Ua.XRegistry C# namespace so its RegistryType /
         GroupType / ResourceType constants coexist with the V1 and V2 models. -->
    <AdditionalFiles Include="Design\Opc.Ua.XRegistry.NodeSet2.xml">
      <ModelSourceGeneratorPrefix>Opc.Ua.XRegistry</ModelSourceGeneratorPrefix>
      <ModelSourceGeneratorName>XRegistry</ModelSourceGeneratorName>
      <ModelSourceGeneratorModelUri>http://opcfoundation.org/UA/xRegistry/</ModelSourceGeneratorModelUri>
    </AdditionalFiles>
    <AdditionalFiles Include="Design\Opc.Ua.XRegistry.NodeSet2.csv" />
    <!-- WoT Connectivity V2 companion model (http://opcfoundation.org/UA/WoT-Con/V2/).
         Emitted into the Opc.Ua.WotCon.V2 C# namespace (a child of the V1
         Opc.Ua.WotCon namespace) so the V2 registry/materialization runtime can
         reference its generated ObjectTypeIds / DataTypes without colliding with
         the legacy 1.02 constants. -->
    <AdditionalFiles Include="Design\Opc.Ua.WoTConV2.NodeSet2.xml">
      <ModelSourceGeneratorPrefix>Opc.Ua.WotCon.V2</ModelSourceGeneratorPrefix>
      <ModelSourceGeneratorName>WotConV2</ModelSourceGeneratorName>
      <ModelSourceGeneratorModelUri>http://opcfoundation.org/UA/WoT-Con/V2/</ModelSourceGeneratorModelUri>
    </AdditionalFiles>
    <AdditionalFiles Include="Design\Opc.Ua.WoTConV2.NodeSet2.csv" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

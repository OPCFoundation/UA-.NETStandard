<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).Robotics.Server</AssemblyName>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.Robotics.Server</PackageId>
    <RootNamespace>Opc.Ua.Robotics.Server</RootNamespace>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <Nullable>enable</Nullable>
    <Description>Server-side reusable functionality for the OPC 40010 Robotics companion model: loads the Robotics + IA + DI type system into a node manager (runtime NodeSet import) and instantiates Robotics-typed objects (MotionDeviceSystem / MotionDevice / Axis / Controller) from the numeric type NodeIds.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Robotics\Opc.Ua.Robotics.csproj" />
    <ProjectReference Include="..\Opc.Ua.Di\Opc.Ua.Di.csproj" />
    <ProjectReference Include="..\Opc.Ua.Server\Opc.Ua.Server.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- PubSub.Diagnostics requires .NET 8+ APIs and reuses the
         Opc.Ua.Core.Diagnostics pcap writers/readers (SharpPcap / PacketDotNet),
         so it follows the same TFM strategy as Opc.Ua.Core.Diagnostics:
         multi-target net8/9/10 when not pinned by CI, otherwise follow
         $(CustomTestTarget). Legacy CI runs (net472/net48/netstandard2.x) strip
         this project to an empty no-op shell via $(RestrictForLegacyTfm). -->
    <TargetFrameworks Condition="'$(CustomTestTarget)' == ''">net8.0;net9.0;net10.0</TargetFrameworks>
    <TargetFrameworks Condition="'$(CustomTestTarget)' == 'net8.0' OR '$(CustomTestTarget)' == 'net9.0' OR '$(CustomTestTarget)' == 'net10.0'">$(CustomTestTarget)</TargetFrameworks>
    <!-- netstandard2.0/2.1 can't host the empty $(RestrictForLegacyTfm) shell
         (CS8021 - no reference assembly defines System.Object), so build those
         shells as net10.0. net472/net48 shells compile empty fine. -->
    <TargetFrameworks Condition="'$(TargetFrameworks)' == '' AND ('$(CustomTestTarget)' == 'netstandard2.0' OR '$(CustomTestTarget)' == 'netstandard2.1')">net10.0</TargetFrameworks>
    <TargetFrameworks Condition="'$(TargetFrameworks)' == ''">$(CustomTestTarget)</TargetFrameworks>
    <RestrictForLegacyTfm>true</RestrictForLegacyTfm>
    <AssemblyName>$(AssemblyPrefix).PubSub.Diagnostics</AssemblyName>
    <PackageId>$(PackagePrefix).Opc.Ua.PubSub.Diagnostics</PackageId>
    <RootNamespace>Opc.Ua.PubSub.Pcap</RootNamespace>
    <Description>OPC UA PubSub diagnostics: capture, dissection (incl. encrypted UADP) and replay of UDP / MQTT PubSub traffic.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <!--
      Legacy TFM builds intentionally compile an empty compatibility shell because PubSub diagnostics is
      net8.0+ only. Suppress empty-shell compiler/assembly warnings for that shell.
      TODO: remove when legacy TFM validation no longer builds the diagnostics compatibility shell.
    -->
    <NoWarn Condition="'$(TargetFramework)' == 'net48' OR '$(TargetFramework)' == 'net472'">$(NoWarn);CS2008;CA1014;CA1016</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Diagnostics.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="System.Threading.Channels" />
    <PackageReference Include="PacketDotNet" />
    <PackageReference Include="SharpPcap" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Core.Diagnostics\Opc.Ua.Core.Diagnostics.csproj" />
    <ProjectReference Include="..\Opc.Ua.PubSub\Opc.Ua.PubSub.csproj" />
    <ProjectReference Include="..\Opc.Ua.PubSub.Udp\Opc.Ua.PubSub.Udp.csproj" />
    <ProjectReference Include="..\Opc.Ua.PubSub.Mqtt\Opc.Ua.PubSub.Mqtt.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

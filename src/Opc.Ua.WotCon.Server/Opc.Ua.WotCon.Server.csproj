<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).WotCon.Server</AssemblyName>
    <DefineConstants>$(DefineConstants);OPCUA_INCLUDE_ASYNC</DefineConstants>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.WotCon.Server</PackageId>
    <RootNamespace>Opc.Ua.WotCon.Server</RootNamespace>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <Nullable>enable</Nullable>
    <Description>OPC UA WoT Connectivity (OPC 10100-1) server class library</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
    <!--
      SYSLIB1100/1101: the configuration binding source generator emits informational
      diagnostics for properties whose type is an interface or non-default-constructible
      class (e.g. IWotAssetDiscoveryProvider, IList<IWotAssetProviderFactory>). Those
      properties are runtime-only and never bound from IConfiguration; the binder
      silently skips them, which is the desired behavior.
      IL2026/IL3050: WotConfigurationParameter.InitialValue is typed as Variant?, and
      the binder generator emits 'new Variant((object)value)' whose ctor has
      RequiresUnreferencedCode/RequiresDynamicCode. The InitialValue path is
      runtime-only and not bound from appsettings; suppress at project level.
    -->
    <NoWarn>$(NoWarn);SYSLIB1100;SYSLIB1101;IL2026;IL3050</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Server\Opc.Ua.Server.csproj" />
    <ProjectReference Include="..\Opc.Ua.Bindings.Https\Opc.Ua.Bindings.Https.csproj" />
    <ProjectReference Include="..\Opc.Ua.WotCon\Opc.Ua.WotCon.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

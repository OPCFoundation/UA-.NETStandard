<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).XRegistry.Server</AssemblyName>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.XRegistry.Server</PackageId>
    <RootNamespace>Opc.Ua.XRegistry.Server</RootNamespace>
    <Description>OPC UA xRegistry generic server-side registry node managers: content-addressed resource resolution (Opaque NodeId fast path), the CreateResource/Write/Close registration lifecycle, and federation.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Server.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.XRegistry.Server.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.XRegistry\Opc.Ua.XRegistry.csproj" />
    <ProjectReference Include="..\Opc.Ua.Server\Opc.Ua.Server.csproj" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

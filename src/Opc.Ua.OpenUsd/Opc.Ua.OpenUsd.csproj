<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).OpenUsd</AssemblyName>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.OpenUsd</PackageId>
    <RootNamespace>Opc.Ua.OpenUsd</RootNamespace>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <Nullable>enable</Nullable>
    <Description>Draft OPC UA - OpenUSD Bindings companion information model (representation, live/alarm/history/command bindings, composition, content integrity and asset content delivery), source-generated from the shared NodeSet2.xml.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.OpenUsd.Server" />
    <InternalsVisibleTo Include="Opc.Ua.OpenUsd.Client" />
    <InternalsVisibleTo Include="Opc.Ua.OpenUsd.Connector" />
    <InternalsVisibleTo Include="Opc.Ua.Robotics.Server" />
    <InternalsVisibleTo Include="PumpDeviceIntegrationServer" />
    <InternalsVisibleTo Include="MinimalRobotServer" />
    <InternalsVisibleTo Include="Opc.Ua.Di.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Server\Opc.Ua.Server.csproj" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\tools\Opc.Ua.SourceGeneration\Opc.Ua.SourceGeneration.csproj">
      <OutputItemType>Analyzer</OutputItemType>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>
  <ItemGroup>
    <None Remove="Model\Opc.Ua.OpenUsd.NodeSet2.xml" />
    <None Remove="Model\Opc.Ua.OpenUsd.NodeSet2.csv" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="Model\Opc.Ua.OpenUsd.NodeSet2.xml">
      <ModelSourceGeneratorPrefix>Opc.Ua.OpenUsd</ModelSourceGeneratorPrefix>
    </AdditionalFiles>
    <AdditionalFiles Include="Model\Opc.Ua.OpenUsd.NodeSet2.csv" />
  </ItemGroup>
  <Import Project="..\..\tools\Opc.Ua.SourceGeneration\OPCFoundation.Opc.Ua.SourceGeneration.props" />
  <PropertyGroup>
    <ModelSourceGeneratorVersion>v105</ModelSourceGeneratorVersion>
    <ModelSourceGeneratorUseAllowSubtypes>true</ModelSourceGeneratorUseAllowSubtypes>
  </PropertyGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

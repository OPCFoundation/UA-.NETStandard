<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).PubSub</AssemblyName>
    <TargetFrameworks>$(LibxTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.PubSub</PackageId>
    <RootNamespace>Opc.Ua.PubSub</RootNamespace>
    <Description>OPC UA PubSub Class Library</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
    <!--
      IUaPubSubDataStore is marked [Obsolete(DiagnosticId = "UA0023")] so consumer
      code sees the migration warning, but the modern PubSubApplicationBuilder and
      DataStoreBackedPublishedDataSetSource still consume it, so we suppress
      UA0023 + CS0618 within the library while keeping the warnings active for
      downstream consumers.
    -->
    <NoWarn>$(NoWarn);UA0023;CS0618;UA_NETStandard_Encoders</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Core\Opc.Ua.Core.csproj" />
    <ProjectReference Include="..\Opc.Ua.Core.Schema\Opc.Ua.Core.Schema.csproj" />
    <ProjectReference Include="..\Opc.Ua.Client\Opc.Ua.Client.csproj" />
    <ProjectReference Include="..\Opc.Ua.XRegistry\Opc.Ua.XRegistry.csproj" />
    <ProjectReference Include="..\Opc.Ua.XRegistry.Client\Opc.Ua.XRegistry.Client.csproj" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="SchemaRegistry\Opc.Ua.SchemaRegistry.NodeSet2.xml" LogicalName="Opc.Ua.PubSub.SchemaRegistry.Opc.Ua.SchemaRegistry.NodeSet2.xml" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
  </ItemGroup>
  <!-- Apache.Arrow backs the Arrow PubSub adapter; only referenced on the modern
       target frameworks where the Arrow encoding is compiled (net8+). -->
  <ItemGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net8.0'))">
    <PackageReference Include="Apache.Arrow" />
  </ItemGroup>
  <Choose>
    <When Condition="'$(TargetFramework)' != 'netstandard2.1' AND '$(TargetFramework)' != 'net48' and '$(TargetFramework)' != 'net472'">
      <ItemGroup>
        <PackageReference Include="MQTTnet" />
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup>
        <PackageReference Include="MQTTnet" VersionOverride="4.3.7.1207" />
      </ItemGroup>
    </Otherwise>
  </Choose>
  <ItemGroup Condition="'$(TargetFrameworkIdentifier)' == '.NETFramework'">
    <!--
      System.Net.NetworkInformation is an in-box assembly on modern TFMs
      (netstandard2.1, net8.0+); only the .NET Framework targets need an
      explicit reference to the framework assembly.
    -->
    <Reference Include="System.Net.NetworkInformation" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

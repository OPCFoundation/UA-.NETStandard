<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(HttpsTargetFrameworks)</TargetFrameworks>
    <AssemblyName>$(AssemblyPrefix).Bindings.Https</AssemblyName>
    <PackageId>$(PackagePrefix).Opc.Ua.Bindings.Https</PackageId>
    <RootNamespace>Opc.Ua.Bindings</RootNamespace>
    <Description>OPC UA Https Binding Library for a Opc.Ua.Server.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.Core.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Sessions.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Bindings.Https.WebApi.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <Choose>
    <When Condition="'$(TargetFramework)' == 'net472' OR '$(TargetFramework)' == 'net48' OR '$(TargetFramework)' == 'netstandard2.1'">
      <ItemGroup>
        <PackageReference Include="Microsoft.AspNetCore.Server.Kestrel" />
        <PackageReference Include="Microsoft.AspNetCore.Server.Kestrel.Core" />
        <PackageReference Include="Microsoft.AspNetCore.Server.Kestrel.Transport.Sockets" />
        <PackageReference Include="Microsoft.AspNetCore.Server.Kestrel.Https" />
        <PackageReference Include="Microsoft.AspNetCore.Http" />
        <PackageReference Include="Microsoft.AspNetCore.WebSockets" />
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
        <!--
          The OPC UA REST binding (Part 6 §G.3 OpenAPI Mapping) folded
          into this package on net8+ exposes Bearer-JWT and Certificate
          (mTLS) authentication helpers via
          OpcUaWebApiAuthenticationBuilderExtensions. The two
          handler packages are intentionally excluded from the
          Microsoft.AspNetCore.App shared framework, so they are
          referenced explicitly.
        -->
        <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
        <PackageReference Include="Microsoft.AspNetCore.Authentication.Certificate" />
      </ItemGroup>
    </Otherwise>
  </Choose>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Core\Opc.Ua.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Properties\" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.Security.Cryptography.Cng" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

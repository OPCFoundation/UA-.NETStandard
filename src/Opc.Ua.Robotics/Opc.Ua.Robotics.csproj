<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).Robotics</AssemblyName>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.Robotics</PackageId>
    <RootNamespace>Opc.Ua.Robotics</RootNamespace>
    <NoWarn>$(NoWarn);CS1591;CS0108</NoWarn>
    <Nullable>enable</Nullable>
    <Description>Shared foundation for the OPC 40010 Robotics companion specification (MotionDeviceSystem -&gt; MotionDevice -&gt; Axis). Source-generated from the Robotics + Industrial Automation (IA) NodeSet2 XMLs over the OPC UA DI base model, exposing the typed model, the AddOpcUaRobotics / AddOpcUaIA loaders, and key type NodeIds. Used together with the draft OPC UA - OpenUSD Bindings model to render a live robot-cell twin.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.Robotics.Server" />
    <InternalsVisibleTo Include="Opc.Ua.Robotics.Client" />
    <InternalsVisibleTo Include="MinimalRobotServer" />
    <InternalsVisibleTo Include="Opc.Ua.Di.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Di\Opc.Ua.Di.csproj" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\tools\Opc.Ua.SourceGeneration\Opc.Ua.SourceGeneration.csproj">
      <OutputItemType>Analyzer</OutputItemType>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>
  <!-- The OPC 40010 Robotics model and its required OPC 40001-1 IA base model are
       source-generated from their NodeSet2 XML over the source-generated OPC UA
       DI base model. The Robotics Programs facet uses the standard
       FileDirectoryType, whose method-state classes a curated Core omits; the
       model generator degrades those absent standard method-state references to
       the base MethodState (see StandardMethodStateFallback), so the model
       compiles. OmitFluentApi keeps the output model-only (Core + DI, no Server
       dependency). -->
  <ItemGroup>
    <None Remove="Model\Opc.Ua.IA.NodeSet2.xml" />
    <None Remove="Model\Opc.Ua.Robotics.NodeSet2.xml" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="Model\Opc.Ua.IA.NodeSet2.xml">
      <ModelSourceGeneratorPrefix>Opc.Ua.IA</ModelSourceGeneratorPrefix>
    </AdditionalFiles>
    <AdditionalFiles Include="Model\Opc.Ua.Robotics.NodeSet2.xml">
      <ModelSourceGeneratorPrefix>Opc.Ua.Robotics</ModelSourceGeneratorPrefix>
    </AdditionalFiles>
  </ItemGroup>
  <Import Project="..\..\tools\Opc.Ua.SourceGeneration\OPCFoundation.Opc.Ua.SourceGeneration.props" />
  <PropertyGroup>
    <ModelSourceGeneratorVersion>v105</ModelSourceGeneratorVersion>
    <ModelSourceGeneratorUseAllowSubtypes>true</ModelSourceGeneratorUseAllowSubtypes>
    <ModelSourceGeneratorOmitFluentApi>true</ModelSourceGeneratorOmitFluentApi>
  </PropertyGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

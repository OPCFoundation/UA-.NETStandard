<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).PubSub.Eth</AssemblyName>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.PubSub.Eth</PackageId>
    <RootNamespace>Opc.Ua.PubSub.Eth</RootNamespace>
    <Description>OPC UA PubSub Ethernet (Layer 2) transport (Part 14 Ethernet mapping, EtherType 0xB62C) class library.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Eth.Tests" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Core\Opc.Ua.Core.csproj" />
    <ProjectReference Include="..\Opc.Ua.PubSub\Opc.Ua.PubSub.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Options" />
    <!--
      SharpPcap (and transitive PacketDotNet) provide the opt-in cross-platform /
      Windows libpcap/Npcap frame backend reached only via WithPcap(). Pinned as a
      native-code dependency in Directory.Packages.props (SDL policy). PacketDotNet
      has no netstandard asset (NU1701 on netstandard2.1), so the reference and the
      pcap backend (#if NET8_0_OR_GREATER) are restricted to net8.0+ — matching the
      Opc.Ua.Core.Diagnostics TFM strategy. The native AF_PACKET (Linux) / BPF
      (macOS) and in-memory backends do not use it and work on every TFM.
    -->
    <PackageReference Include="SharpPcap"
      Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net8.0'))" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFrameworkIdentifier)' == '.NETFramework'">
    <!--
      System.Net.NetworkInformation is an in-box assembly on modern TFMs
      (netstandard2.1, net8.0+); only the .NET Framework targets need an
      explicit reference to the framework assembly.
    -->
    <Reference Include="System.Net.NetworkInformation" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
</Project>

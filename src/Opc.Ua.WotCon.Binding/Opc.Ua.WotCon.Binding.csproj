<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).WotCon.Binding</AssemblyName>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.WotCon.Binding</PackageId>
    <RootNamespace>Opc.Ua.WotCon.Binding</RootNamespace>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <Nullable>enable</Nullable>
    <Description>OPC UA WoT Connectivity protocol-binding abstractions and planners (dependency-light)</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Server" />
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Binding.Http" />
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Binding.Mqtt" />
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Binding.Modbus" />
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Binding.OpcUa" />
    <InternalsVisibleTo Include="Opc.Ua.WotCon.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.WotCon\Opc.Ua.WotCon.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

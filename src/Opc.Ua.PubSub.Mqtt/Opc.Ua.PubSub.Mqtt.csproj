<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).PubSub.Mqtt</AssemblyName>
    <TargetFrameworks>$(LibxTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.PubSub.Mqtt</PackageId>
    <RootNamespace>Opc.Ua.PubSub.Mqtt</RootNamespace>
    <Description>OPC UA PubSub MQTT transport (Part 14 §7.3.4) class library.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Mqtt.Tests" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Core\Opc.Ua.Core.csproj" />
    <ProjectReference Include="..\Opc.Ua.PubSub\Opc.Ua.PubSub.csproj" />
  </ItemGroup>
  <!--
    MQTTnet dual-version: latest v5 on modern .NET targets, pinned v4.3.7.1207 on
    netstandard2.1 / net48 / net472. Matches the dual-version pattern from the
    legacy Opc.Ua.PubSub.csproj so existing deployments are not forced off
    MQTTnet v4 until they move to a modern TFM.
  -->
  <Choose>
    <When Condition="'$(TargetFramework)' != 'netstandard2.1' AND '$(TargetFramework)' != 'net48' and '$(TargetFramework)' != 'net472'">
      <ItemGroup>
        <PackageReference Include="MQTTnet" />
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup>
        <PackageReference Include="MQTTnet" VersionOverride="4.3.7.1207" />
      </ItemGroup>
    </Otherwise>
  </Choose>
  <Target Name="GetPackagingOutputs" />
</Project>

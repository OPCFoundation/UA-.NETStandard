<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(LibCoreTargetFrameworks);netstandard2.0</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.Types</PackageId>
    <AssemblyName>$(AssemblyPrefix).Types</AssemblyName>
    <RootNamespace>Opc.Ua</RootNamespace>
    <Description>OPC UA Type Library</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.Core.Types" />
    <InternalsVisibleTo Include="Opc.Ua.Types.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Core.Encoders.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.SourceGeneration.Core.Tests" />
  </ItemGroup>
  <!-- The Arrow reference encoder requires Apache.Arrow and modern .NET; its source
       files self-exclude on the legacy target frameworks (net472/net48/netstandard2.0/
       netstandard2.1) via #if NET8_0_OR_GREATER guards. The Avro reference encoder is
       supported on every target framework: net5+ BCL APIs (BitConverter bit-casts,
       Convert.ToHexString, Stream.ReadExactly, span-based Encoding) are provided by
       EncoderCompat and the polyfills under Polyfills\ on the legacy frameworks. -->
  <ItemGroup>
    <PackageReference Include="System.Collections.Immutable" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>
  <!-- Apache.Arrow backs the Arrow reference encoder; it is only referenced on the
       modern target frameworks where the Arrow encoders are compiled (net8+). -->
  <ItemGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net8.0'))">
    <PackageReference Include="Apache.Arrow" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0' OR '$(TargetFramework)' == 'net472' OR '$(TargetFramework)' == 'net48'">
    <PackageReference Include="Microsoft.Bcl.HashCode" />
    <PackageReference Include="System.Threading.Tasks.Extensions" />
    <PackageReference Include="System.Diagnostics.DiagnosticSource" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0' OR '$(TargetFramework)' == 'net472' OR '$(TargetFramework)' == 'net48' OR '$(TargetFramework)' == 'netstandard2.1'">
    <PackageReference Include="System.Text.Json" />
  </ItemGroup>
  <!-- Polyfills for .NET Standard 2.0 and .net 4.8 -->
  <ItemGroup>
    <PackageReference Include="PolySharp" PrivateAssets="All" />
  </ItemGroup>
  <PropertyGroup>
    <PolySharpUsePublicAccessibilityForGeneratedTypes>true</PolySharpUsePublicAccessibilityForGeneratedTypes>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="Schema\BuiltInTypes.xml" />
    <EmbeddedResource Include="Schema\UANodeSet.xsd" />
    <EmbeddedResource Include="Schema\BuiltInTypes.bsd" />
    <EmbeddedResource Include="Schema\StandardTypes.bsd" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

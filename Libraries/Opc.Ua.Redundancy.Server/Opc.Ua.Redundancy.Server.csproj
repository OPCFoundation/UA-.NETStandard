<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.Redundancy.Server</PackageId>
    <AssemblyName>$(AssemblyPrefix).Redundancy.Server</AssemblyName>
    <RootNamespace>Opc.Ua.Redundancy.Server</RootNamespace>
    <Description>OPC UA Distributed / High-Availability Server Class Library</Description>
    <RestoreProjectStyle>PackageReference</RestoreProjectStyle>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.Server.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Redundancy.Server.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Aot.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Crdt" />
    <PackageReference Include="Crdt.Transport" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.Server\Opc.Ua.Server.csproj" />
    <ProjectReference Include="..\Opc.Ua.Redundancy\Opc.Ua.Redundancy.csproj" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).PubSub.Legacy</AssemblyName>
    <TargetFrameworks>$(LibxTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.PubSub.Legacy</PackageId>
    <RootNamespace>Opc.Ua.PubSub</RootNamespace>
    <Description>OPC UA PubSub legacy (1.04) compatibility shims for OPCFoundation.NetStandard.Opc.Ua.PubSub.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
    <!--
      This assembly contains the legacy 1.04 PubSub types (UaPubSubApplication,
      IUaPubSubConnection, UaPubSubConfigurator, the 1.04 UADP/JSON encoders and
      UDP/MQTT transports, ...) extracted out of Opc.Ua.PubSub. The types remain
      marked [Obsolete(DiagnosticId = "UA0023")] so downstream consumers still see
      the migration warning, and the shims forward to the modern Opc.Ua.PubSub
      runtime. UA0023 + CS0618 are suppressed within this library since it
      references its own obsolete types, while the warnings stay active for
      downstream consumers.
    -->
    <NoWarn>$(NoWarn);UA0023;CS0618</NoWarn>
  </PropertyGroup>
  <PropertyGroup Condition="'$(TargetFramework)' == 'net472' OR '$(TargetFramework)' == 'net48'">
    <!--
      Same suppression as Libraries/Opc.Ua.PubSub.csproj / Opc.Ua.Client.csproj:
      the transitive Microsoft.Extensions.Http.Resilience / Telemetry /
      AmbientMetadata packages bleed "doesn't support net48/net472" warnings from
      their buildTransitive targets even though net462 assets are shipped.
      Suppress here to match the rest of the library set. TODO: drop when the
      package matrix stops warning.
    -->
    <SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Legacy.Tests" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Stack\Opc.Ua.Core\Opc.Ua.Core.csproj" />
    <ProjectReference Include="..\Opc.Ua.Client\Opc.Ua.Client.csproj" />
    <ProjectReference Include="..\Opc.Ua.PubSub\Opc.Ua.PubSub.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
  </ItemGroup>
  <Choose>
    <When Condition="'$(TargetFramework)' != 'netstandard2.1' AND '$(TargetFramework)' != 'net48' and '$(TargetFramework)' != 'net472'">
      <ItemGroup>
        <PackageReference Include="MQTTnet" />
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup>
        <PackageReference Include="MQTTnet" VersionOverride="4.3.7.1207" />
      </ItemGroup>
    </Otherwise>
  </Choose>
  <ItemGroup Condition="'$(TargetFrameworkIdentifier)' == '.NETFramework'">
    <!--
      System.Net.NetworkInformation is an in-box assembly on modern TFMs
      (netstandard2.1, net8.0+); only the .NET Framework targets need an
      explicit reference to the framework assembly.
    -->
    <Reference Include="System.Net.NetworkInformation" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.PubSub.Redundancy</PackageId>
    <AssemblyName>$(AssemblyPrefix).PubSub.Redundancy</AssemblyName>
    <RootNamespace>Opc.Ua.PubSub.Redundancy</RootNamespace>
    <Description>OPC UA PubSub High-Availability: distributed active/standby redundancy (Part 14 §9.1.6) backed by the shared redundancy building blocks.</Description>
    <RestoreProjectStyle>PackageReference</RestoreProjectStyle>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Redundancy.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Aot.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.PubSub\Opc.Ua.PubSub.csproj" />
    <ProjectReference Include="..\Opc.Ua.Redundancy\Opc.Ua.Redundancy.csproj" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(LibCoreTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.Security.Certificates</PackageId>
    <AssemblyName>$(AssemblyPrefix).Security.Certificates</AssemblyName>
    <RootNamespace>Opc.Ua.Security.Certificates</RootNamespace>
    <Description>OPC UA Security X509 Certificates Class Library</Description>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.Security.Certificates.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Core.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Core" />
    <InternalsVisibleTo Include="Opc.Ua.Client" />
    <InternalsVisibleTo Include="Opc.Ua.Server" />
    <InternalsVisibleTo Include="Opc.Ua.Configuration" />
    <InternalsVisibleTo Include="Opc.Ua.Gds.Server.Common" />
    <InternalsVisibleTo Include="Opc.Ua.Gds.Client.Common" />
    <InternalsVisibleTo Include="Opc.Ua.PubSub" />
    <InternalsVisibleTo Include="Opc.Ua.Client.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Server.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Configuration.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Gds.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.Collections.Immutable" />
    <PackageReference Include="System.Diagnostics.DiagnosticSource" />
    <PackageReference Include="System.Formats.Asn1" />
    <PackageReference Include="System.Text.Json" />
  </ItemGroup>
  <!-- Add additional crypto library version -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net472' OR '$(TargetFramework)' == 'net48'">
    <PackageReference Include="BouncyCastle.Cryptography" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Stack\Opc.Ua.Types\Opc.Ua.Types.csproj" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <Target Name="GetPackagingOutputs" />
</Project>

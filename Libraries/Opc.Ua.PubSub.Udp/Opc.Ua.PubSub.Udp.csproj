<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).PubSub.Udp</AssemblyName>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.PubSub.Udp</PackageId>
    <RootNamespace>Opc.Ua.PubSub.Udp</RootNamespace>
    <Description>OPC UA PubSub UDP transport (Part 14 §7.3.2) class library.</Description>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Udp.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Bench" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <PropertyGroup Condition="'$(TargetFramework)' == 'net472' OR '$(TargetFramework)' == 'net48'">
    <!--
      Same suppression as Libraries/Opc.Ua.PubSub.csproj / Opc.Ua.Client.csproj:
      transitive Microsoft.Extensions.Http.Resilience / Telemetry packages emit
      "doesn't support net48/net472" buildTransitive warnings even though
      net462 assets are shipped. Suppressed here to match the rest of the
      library set. TODO: drop when the package matrix stops warning.
    -->
    <SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Stack\Opc.Ua.Core\Opc.Ua.Core.csproj" />
    <ProjectReference Include="..\Opc.Ua.PubSub\Opc.Ua.PubSub.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.Net.NetworkInformation" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>$(AssemblyPrefix).PubSub.Kafka</AssemblyName>
    <TargetFrameworks>$(LibxTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.PubSub.Kafka</PackageId>
    <RootNamespace>Opc.Ua.PubSub.Kafka</RootNamespace>
    <Description>OPC UA PubSub Apache Kafka transport (Part 14 Annex B.2) class library.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
    <!--
      Dual-source Kafka client by TFM: net10.0 uses the pure-managed Dekaf client
      (no native dependency) so the transport is NativeAOT/trim-compatible; the older
      TFMs use Confluent.Kafka (native librdkafka), which is not AOT-safe. IsAotCompatible
      is therefore only asserted on net10.0.
    -->
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.PubSub.Kafka.Tests" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Stack\Opc.Ua.Core\Opc.Ua.Core.csproj" />
    <ProjectReference Include="..\Opc.Ua.PubSub\Opc.Ua.PubSub.csproj" />
  </ItemGroup>
  <!-- net10.0 -> Dekaf (pure-managed, AOT); all other TFMs -> Confluent.Kafka (native). -->
  <ItemGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">
    <PackageReference Include="Dekaf" />
  </ItemGroup>
  <ItemGroup Condition="!$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">
    <PackageReference Include="Confluent.Kafka" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
</Project>

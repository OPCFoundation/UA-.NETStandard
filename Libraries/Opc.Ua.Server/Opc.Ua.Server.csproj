<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(LibTargetFrameworks)</TargetFrameworks>
    <PackageId>$(PackagePrefix).Opc.Ua.Server</PackageId>
    <AssemblyName>$(AssemblyPrefix).Server</AssemblyName>
    <RootNamespace>Opc.Ua.Server</RootNamespace>
    <Description>OPC UA Server Class Library</Description>
    <RestoreProjectStyle>PackageReference</RestoreProjectStyle>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">true</IsAotCompatible>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.Server.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Server.TestFramework" />
    <InternalsVisibleTo Include="Opc.Ua.Session.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Sessions.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Subscriptions.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Subscriptions.Durable.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Features.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Stress.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.InformationModel.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.History.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Lds.Tests" />
    <InternalsVisibleTo Include="Opc.Ua.Core.Security.Tests" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Stack\Opc.Ua.Core\Opc.Ua.Core.csproj" />
    <ProjectReference Include="..\..\Stack\Opc.Ua.Core.Schema\Opc.Ua.Core.Schema.csproj" />
    <ProjectReference Include="..\Opc.Ua.Configuration\Opc.Ua.Configuration.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="System.Threading.RateLimiting" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net48' OR '$(TargetFramework)' == 'net472'">
    <Reference Include="System.Net.Http" />
  </ItemGroup>
  <Target Name="GetPackagingOutputs" />
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

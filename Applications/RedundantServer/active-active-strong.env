# Active/active, strong consistency (Raft). All three replicas serve data; the
# shared key/value store, single-use nonce, and lease are linearizable over a
# 3-node RaftCs cluster (a fault-tolerant quorum tolerates losing one replica).
#
#   docker compose --env-file Applications/RedundantServer/active-active-strong.env \
#     -f Applications/RedundantServer/docker-compose.yml up --build
HA_MODE=aa
HA_CONSISTENCY=strong
CLIENT_REPLICAS=1
# Isolated demo posture: run the Raft-backed store and gossip without record
# protection / gossip authentication. For a secure run, REMOVE HA_INSECURE,
# configure mutual TLS on the gossip transport, and set HA_RECORD_KEY to a
# shared base64 32-byte key on every replica.
HA_INSECURE=true

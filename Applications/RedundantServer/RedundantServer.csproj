<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework Condition="'$(CustomTestTarget)' == ''">net10.0</TargetFramework>
    <TargetFramework Condition="'$(CustomTestTarget)' != ''">$(CustomTestTarget)</TargetFramework>
    <OutputType>Exe</OutputType>
    <AssemblyName>RedundantServer</AssemblyName>
    <PackageId>RedundantServer</PackageId>
    <Company>OPC Foundation</Company>
    <Description>Minimal .NET console OPC UA server demonstrating distributed high-availability address-space replication, service-level publishing, and server redundancy metadata.</Description>
    <Copyright>Copyright © 2004-2025 OPC Foundation, Inc</Copyright>
    <RootNamespace>RedundantServer</RootNamespace>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);CA1822</NoWarn>
    <PublishAot>true</PublishAot>
    <!-- Opt into the root Directory.Build.targets no-op shape on
         per-TFM CI matrix entries that pin CustomTestTarget to a
         legacy TFM this app cannot target. -->
    <RestrictForLegacyTfm>true</RestrictForLegacyTfm>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Configuration\Opc.Ua.Configuration.csproj" />
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Server\Opc.Ua.Server.csproj" />
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Redundancy.Server\Opc.Ua.Redundancy.Server.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
    <PackageReference Include="RaftCs.Transport.NanoMsg" />
  </ItemGroup>
</Project>

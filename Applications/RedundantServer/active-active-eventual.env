# Active/active, eventual consistency (CRDT gossip). Two or three replicas accept
# writes and converge their address space over gossip; no external shared store.
# This is the default topology.
#
#   docker compose --env-file Applications/RedundantServer/active-active-eventual.env \
#     -f Applications/RedundantServer/docker-compose.yml up --build
HA_MODE=aa
HA_CONSISTENCY=eventual
CLIENT_REPLICAS=1
# Isolated demo posture: run CRDT gossip without record protection or gossip
# authentication. For a secure run, REMOVE HA_INSECURE, configure mutual TLS on
# the gossip transport (GossipTlsOptions), and set HA_RECORD_KEY to a shared
# base64 32-byte key on every replica.
HA_INSECURE=true

# Active/passive, strong consistency (Raft). Exactly one replica is the Raft leader
# (the active writer); the other two are hot standbys that take over on leader loss.
# The 3-node RaftCs cluster keeps a quorum (2 of 3) when one replica fails.
#
#   docker compose --env-file Applications/RedundantServer/active-passive.env \
#     -f Applications/RedundantServer/docker-compose.yml up --build
HA_MODE=ap
HA_CONSISTENCY=strong
REDUNDANCY_MODE=hot
CLIENT_REPLICAS=1
# Isolated demo posture: run the Raft-backed store without record protection.
# For a secure run, REMOVE HA_INSECURE and set HA_RECORD_KEY to a shared base64
# 32-byte key on every replica (e.g. HA_RECORD_KEY=$(openssl rand -base64 32)),
# provisioned from a Kubernetes Secret / KMS in production.
HA_INSECURE=true

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UaLens.Views.ConnectDialog"
        Title="Connect to OPC UA server"
        Width="460" Height="260"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0">
  <Grid Margin="14" RowDefinitions="*,Auto">

    <!-- Body: one TabControl with a single URL tab today.  Future MDNS,
         LDS, and reverse-connect connection sources slot in here as
         additional TabItems whose content implements
         IConnectionSourceTab. -->
    <TabControl Grid.Row="0" x:Name="SourcesTabs" Background="Transparent">
      <TabItem Header="URL">
        <!-- The Content here must implement IConnectionSourceTab. -->
        <Grid Margin="8,12,8,8" RowDefinitions="Auto,Auto" x:Name="UrlTabRoot">
          <TextBlock Grid.Row="0" Margin="0,0,0,6" Foreground="#94A3B8" FontSize="11"
                     Text="Endpoint URL" />
          <TextBox Grid.Row="1" x:Name="EndpointUrlBox"
                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                   Watermark="opc.tcp://localhost:62541/Quickstarts/ReferenceServer" />
        </Grid>
      </TabItem>
      <!-- Future: MDNS / LDS / Reverse-Connect tabs added here. Each new
           tab's Content control implements IConnectionSourceTab and
           returns the chosen endpoint URL via GetEndpointUrl().  No
           changes needed in ConnectDialog.axaml.cs's button handlers. -->
    </TabControl>

    <StackPanel Grid.Row="1" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,12,0,0" Spacing="6">
      <Button x:Name="ConnectButton" Content="Connect" IsDefault="True"
              Width="120" Background="#0EA5E9" Foreground="#0F172A" FontWeight="SemiBold" />
      <Button x:Name="CancelButton"  Content="Cancel"  IsCancel="True" Width="100" />
    </StackPanel>
  </Grid>
</Window>

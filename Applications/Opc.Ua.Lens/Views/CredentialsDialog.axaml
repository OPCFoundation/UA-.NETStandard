<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UaLens.Views.CredentialsDialog"
        Title="User credentials"
        Width="420" Height="220"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0">
  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*,Auto" ColumnDefinitions="120,*">

    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12"
               Text="Enter the user credentials for the selected UserName policy." />

    <TextBlock Grid.Row="1" Grid.Column="0" Text="Username" VerticalAlignment="Center" />
    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="UsernameBox" />

    <TextBlock Grid.Row="2" Grid.Column="0" Text="Password" VerticalAlignment="Center" Margin="0,8,0,0" />
    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="PasswordBox" PasswordChar="●" Margin="0,8,0,0" />

    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="OkButton"     Content="OK"     IsDefault="True"  Width="100" />
      <Button x:Name="CancelButton" Content="Cancel" IsCancel="True"   Width="100" Margin="8,0,0,0" />
    </StackPanel>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UaLens.Views.EncodingPickerDialog"
        Title="Pick encoding"
        Width="360" Height="220"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0">
  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
    <TextBlock Grid.Row="0" Margin="0,0,0,12" TextWrapping="Wrap"
               Text="Pick the OPC UA value encoding." />
    <RadioButton Grid.Row="1" x:Name="BinaryRadio" GroupName="Fmt" Content="Binary" Margin="0,2" />
    <RadioButton Grid.Row="2" x:Name="XmlRadio"    GroupName="Fmt" Content="XML"    Margin="0,2" />
    <RadioButton Grid.Row="3" x:Name="JsonRadio"   GroupName="Fmt" Content="JSON"   Margin="0,2" />
    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="OkButton"     Content="OK"     IsDefault="True" Width="100" />
      <Button x:Name="CancelButton" Content="Cancel" IsCancel="True"  Width="100" Margin="8,0,0,0" />
    </StackPanel>
  </Grid>
</Window>

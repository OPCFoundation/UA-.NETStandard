<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UaLens.ViewModels"
             xmlns:v="using:UaLens.Views"
             x:Class="UaLens.Views.AddressSpaceView"
             x:DataType="vm:BrowserViewModel">
  <Border BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="4" Padding="0">
    <Grid RowDefinitions="Auto,Auto,*">
      <DockPanel Grid.Row="0" Margin="4,4,4,2" LastChildFill="True"
                 IsVisible="{CompiledBinding ShowFilters, Mode=OneWay}">
        <TextBlock DockPanel.Dock="Left"
                   VerticalAlignment="Center"
                   Margin="0,0,4,0"
                   Foreground="{DynamicResource TextSecondary}"
                   Text="View:" />
        <ComboBox x:Name="ViewKindCombo"
                  HorizontalAlignment="Stretch"
                  MinHeight="24"
                  VerticalAlignment="Center"
                  VerticalContentAlignment="Center"
                  ToolTip.Tip="Re-roots the address-space tree (Objects / type hierarchies / Views)." />
      </DockPanel>
      <TextBox Grid.Row="1" x:Name="SearchBox" Margin="4,4,4,2"
               Watermark="Search BrowseName / NodeId (Enter, F3 next)"
               FontFamily="Cascadia Mono, Consolas, monospace"
               IsVisible="{CompiledBinding ShowFilters, Mode=OneWay}" />
      <TreeView Grid.Row="2" x:Name="Tree"
                ItemsSource="{CompiledBinding Roots}"
                Background="{DynamicResource AppBg}"
                Foreground="{DynamicResource TextPrimary}"
                BorderThickness="0">
        <TreeView.ContextMenu>
          <ContextMenu x:Name="NodeMenu">
            <MenuItem x:Name="MenuAddItem"   Header="Add Item…" />
            <MenuItem x:Name="MenuAddRecursive" Header="Add Recursively…" />
            <MenuItem x:Name="MenuCallMethod" Header="Call Method…" />
            <MenuItem x:Name="MenuWriteValue" Header="Write Value…" />
            <MenuItem x:Name="MenuReadHistory" Header="Read history…" />
            <MenuItem x:Name="MenuShowEvents" Header="Show Events…" />
            <MenuItem x:Name="MenuPerf" Header="Perf…" />
            <MenuItem x:Name="MenuExportValue" Header="Export value to file…" />
            <Separator />
            <MenuItem x:Name="MenuFindByPath" Header="Find by path…" />
            <MenuItem x:Name="MenuViewNodeState" Header="View NodeState…" />
          </ContextMenu>
        </TreeView.ContextMenu>
        <TreeView.ItemTemplate>
          <TreeDataTemplate DataType="vm:NodeViewModel" ItemsSource="{CompiledBinding Children}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <!-- Code-editor-style letter tile (see NodeClassIcons.Tiles).
                   Concrete instances render with a solid accent fill and
                   white letter; type kinds render with a transparent fill,
                   accent border and accent-coloured letter so the eye
                   pairs each "X type" tile with its "X instance" tile.
                   Hidden when NodeClass has no tile (Unspecified). -->
              <Border Width="14" Height="14" CornerRadius="3"
                      BorderThickness="1.2"
                      VerticalAlignment="Center"
                      IsVisible="{CompiledBinding NodeClass, Converter={x:Static v:NodeClassToIconVisibilityConverter.Instance}}"
                      Background="{CompiledBinding NodeClass, Converter={x:Static v:NodeClassToFillConverter.Instance}}"
                      BorderBrush="{CompiledBinding NodeClass, Converter={x:Static v:NodeClassToStrokeConverter.Instance}}">
                <TextBlock Text="{CompiledBinding NodeClass, Converter={x:Static v:NodeClassToLetterConverter.Instance}}"
                           Foreground="{CompiledBinding NodeClass, Converter={x:Static v:NodeClassToForegroundConverter.Instance}}"
                           FontFamily="Cascadia Mono, Consolas, monospace"
                           FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center"
                           ToolTip.Tip="{CompiledBinding NodeClass}" />
              </Border>
              <TextBlock Text="{CompiledBinding Text}" VerticalAlignment="Center" />
            </StackPanel>
          </TreeDataTemplate>
        </TreeView.ItemTemplate>
        <TreeView.Styles>
          <Style Selector="TreeViewItem" x:DataType="vm:NodeViewModel">
            <Setter Property="IsExpanded" Value="{CompiledBinding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Padding" Value="4,2" />
          </Style>
        </TreeView.Styles>
      </TreeView>
    </Grid>
  </Border>
</UserControl>




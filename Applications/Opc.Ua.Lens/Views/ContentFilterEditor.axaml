<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UaLens.Views.ContentFilterEditor"
             Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}">
  <Grid RowDefinitions="*,Auto" Margin="0">

    <Grid Grid.Row="0" ColumnDefinitions="240,*" Margin="0">

      <!-- Left pane: element list -->
      <Border Grid.Column="0" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="4"
              Padding="6" Background="{DynamicResource PanelBg}" Margin="0,0,8,0">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock Grid.Row="0" Text="Elements"
                     FontWeight="SemiBold" Foreground="{DynamicResource AccentCyan}" Margin="2,0,0,6" />
          <ListBox Grid.Row="1" x:Name="ElementsList"
                   Background="Transparent"
                   DisplayMemberBinding="{Binding Summary}" />
          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Stretch"
                      Spacing="4" Margin="0,6,0,0">
            <Button x:Name="AddElementBtn"    Content="+"  Width="32" ToolTip.Tip="Add element" />
            <Button x:Name="RemoveElementBtn" Content="-"  Width="32" ToolTip.Tip="Remove element" />
            <Button x:Name="MoveUpBtn"        Content="▲"  Width="32" ToolTip.Tip="Move up" />
            <Button x:Name="MoveDownBtn"      Content="▼"  Width="32" ToolTip.Tip="Move down" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Right pane: element editor -->
      <Border Grid.Column="1" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="4"
              Padding="10" Background="{DynamicResource PanelBg}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="*">
          <TextBlock Grid.Row="0" Text="Element editor"
                     FontWeight="SemiBold" Foreground="{DynamicResource AccentCyan}" Margin="0,0,0,6" />

          <Grid Grid.Row="1" ColumnDefinitions="120,*" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" Text="Operator" VerticalAlignment="Center" />
            <ComboBox  Grid.Column="1" x:Name="OperatorCombo" HorizontalAlignment="Stretch" />
          </Grid>

          <TextBlock Grid.Row="2" Text="Operands"
                     FontWeight="SemiBold" Foreground="{DynamicResource AccentYellow}" Margin="0,4,0,4" />

          <ListBox Grid.Row="3" x:Name="OperandsList"
                   Background="Transparent" Height="160" />

          <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="4" Margin="0,6,0,0"
                      HorizontalAlignment="Left" VerticalAlignment="Top">
            <Button x:Name="AddOperandBtn"    Content="Add…"    Width="80" />
            <Button x:Name="EditOperandBtn"   Content="Edit…"   Width="80" />
            <Button x:Name="RemoveOperandBtn" Content="Remove"  Width="80" />
          </StackPanel>

          <TextBlock Grid.Row="5" x:Name="EditorStatus"
                     Foreground="{DynamicResource TextSecondary}" FontSize="11"
                     TextWrapping="Wrap" Margin="0,6,0,0" />
        </Grid>
      </Border>
    </Grid>

    <!-- Preview -->
    <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="4"
            Padding="8" Margin="0,8,0,0" Background="{DynamicResource PanelBg}">
      <StackPanel Spacing="2">
        <TextBlock Text="ContentFilter preview"
                   FontWeight="SemiBold" Foreground="{DynamicResource AccentYellow}" />
        <TextBlock x:Name="PreviewText"
                   FontFamily="Cascadia Mono, Consolas, monospace"
                   FontSize="11" TextWrapping="Wrap"
                   MaxHeight="120" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

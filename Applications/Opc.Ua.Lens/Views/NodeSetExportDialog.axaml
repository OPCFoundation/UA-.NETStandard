<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="using:UaLens.Views"
        x:Class="UaLens.Views.NodeSetExportDialog"
        Title="Export NodeSet2 — select namespaces"
        Width="640" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0">
  <Grid Margin="14" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock Grid.Row="0"
               Margin="0,0,0,8"
               TextWrapping="Wrap"
               Text="Choose which server namespaces to include in the NodeSet2 export. The OPC UA base namespace (ns=0) is always excluded." />

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8" Spacing="6">
      <Button x:Name="SelectAllBtn"  Content="Select all" />
      <Button x:Name="SelectNoneBtn" Content="Select none" />
    </StackPanel>

    <Border Grid.Row="2" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4" Background="#0B1220">
      <ScrollViewer>
        <ItemsControl x:Name="NamespaceList">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="v:NsRow">
              <CheckBox IsChecked="{CompiledBinding Selected, Mode=TwoWay}" Margin="8,4">
                <TextBlock Text="{CompiledBinding Display}"
                           FontFamily="Cascadia Mono, Consolas, monospace"
                           FontSize="11"
                           TextWrapping="Wrap" />
              </CheckBox>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="OkButton"     Content="Export"  IsDefault="True"  Width="100" />
      <Button x:Name="CancelButton" Content="Cancel"  IsCancel="True"   Width="100" Margin="8,0,0,0" />
    </StackPanel>
  </Grid>
</Window>


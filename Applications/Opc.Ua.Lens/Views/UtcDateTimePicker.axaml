<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UaLens.Views.UtcDateTimePicker">
  <StackPanel Orientation="Horizontal" Spacing="6">
    <CalendarDatePicker x:Name="DatePart" Width="160" />
    <TimePicker x:Name="TimePart" ClockIdentifier="24HourClock" Width="160" />
  </StackPanel>
</UserControl>

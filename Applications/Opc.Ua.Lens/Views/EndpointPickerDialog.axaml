<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="using:UaLens.Views"
        x:Class="UaLens.Views.EndpointPickerDialog"
        Title="Select endpoint"
        Width="780" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0">
  <Grid Margin="14" RowDefinitions="Auto,*,Auto,Auto" ColumnDefinitions="*">
    <TextBlock Grid.Row="0"
               Margin="0,0,0,8"
               TextWrapping="Wrap"
               Text="Pick an endpoint or expand it and pick a user-token policy.  Selecting the endpoint root connects with the Anonymous token; expanding lets you choose UserName credentials." />

    <Border Grid.Row="1" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4" Background="#0B1220">
      <TreeView x:Name="Tree"
                Background="Transparent"
                Foreground="#E2E8F0"
                BorderThickness="0">
        <TreeView.Styles>
          <Style Selector="TreeViewItem" x:DataType="v:PickerNode">
            <Setter Property="IsExpanded" Value="{CompiledBinding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsEnabled"  Value="{CompiledBinding IsSelectable}" />
            <Setter Property="Padding"    Value="4,2" />
          </Style>
        </TreeView.Styles>
        <TreeView.ItemTemplate>
          <TreeDataTemplate DataType="v:PickerNode" ItemsSource="{CompiledBinding Children}">
            <TextBlock Text="{CompiledBinding Display}" FontFamily="Cascadia Mono, Consolas, monospace" />
          </TreeDataTemplate>
        </TreeView.ItemTemplate>
      </TreeView>
    </Border>

    <TextBlock Grid.Row="2"
               x:Name="StatusLabel"
               Margin="0,8,0,0"
               Foreground="#94A3B8"
               FontSize="11"
               Text="Loading endpoints…" />

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="OkButton"     Content="OK"     IsDefault="True"  Width="100" />
      <Button x:Name="CancelButton" Content="Cancel" IsCancel="True"   Width="100" Margin="8,0,0,0" />
    </StackPanel>
  </Grid>
</Window>


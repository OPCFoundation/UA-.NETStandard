<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="using:UaLens.Views"
        x:Class="UaLens.Plugins.EventView.WhereClauseDialog"
        Title="Edit where clause"
        Width="960" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0">
  <Grid Margin="16" RowDefinitions="Auto,*,Auto,Auto">

    <TextBlock Grid.Row="0"
               Margin="0,0,0,8"
               TextWrapping="Wrap"
               Foreground="#94A3B8"
               FontSize="12"
               Text="Build a ContentFilter expression that the server applies before delivering events. Each row is a ContentFilterElement (operator + operands). Hit Validate to check the structure against the live session before applying." />

    <v:ContentFilterEditor Grid.Row="1" x:Name="WhereClauseEditor" />

    <TextBlock Grid.Row="2" x:Name="ValidationStatus"
               Margin="0,8,0,0"
               FontFamily="Cascadia Mono, Consolas, monospace"
               FontSize="11"
               TextWrapping="Wrap"
               Foreground="#94A3B8" />

    <StackPanel Grid.Row="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="ClearButton"    Content="Clear"    Width="100" Margin="0,0,8,0" />
      <Button x:Name="ValidateButton" Content="Validate" Width="100" Margin="0,0,8,0" />
      <Button x:Name="OkButton"       Content="Apply"    IsDefault="True" Width="100" />
      <Button x:Name="CancelButton"   Content="Cancel"   IsCancel="True"  Width="100" Margin="8,0,0,0" />
    </StackPanel>
  </Grid>
</Window>

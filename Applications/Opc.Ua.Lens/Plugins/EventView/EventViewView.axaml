<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UaLens.Plugins.EventView"
             x:Class="UaLens.Plugins.EventView.EventViewView"
             x:DataType="vm:EventViewPlugin"
             Background="#121A2C" Foreground="#E2E8F0">
  <UserControl.Resources>
    <SolidColorBrush x:Key="PanelBg"      Color="#0B1220" />
    <SolidColorBrush x:Key="PanelBorder"  Color="#1E293B" />
    <SolidColorBrush x:Key="LabelDim"     Color="#94A3B8" />
    <SolidColorBrush x:Key="ColumnDim"    Color="#64748B" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock.colHeader">
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="#94A3B8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.colCell">
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="#1E293B" />
      <Setter Property="Foreground" Value="#E2E8F0" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{StaticResource PanelBg}" />
    </Style>
  </UserControl.Styles>

  <DockPanel LastChildFill="True">

    <!-- ========= Filter / toolbar bar ========= -->
    <Border DockPanel.Dock="Top" Classes="panel" Margin="8,8,8,4" Padding="8,6">
      <DockPanel LastChildFill="False">
        <TextBlock VerticalAlignment="Center"
                   Foreground="{StaticResource LabelDim}"
                   FontSize="12" Margin="0,0,8,0"
                   Text="🔔 Events" />

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock VerticalAlignment="Center"
                     Foreground="{StaticResource LabelDim}"
                     FontSize="11" Text="Min severity" />
          <Slider Minimum="0" Maximum="1000"
                  Value="{CompiledBinding Filter.SeverityThreshold, Mode=OneWay}"
                  Width="160" VerticalAlignment="Center"
                  IsHitTestVisible="False"
                  ToolTip.Tip="Use Edit Filter… to change" />
          <TextBlock VerticalAlignment="Center"
                     FontFamily="Cascadia Mono, Consolas, monospace"
                     FontSize="11"
                     MinWidth="32"
                     Text="{CompiledBinding Filter.SeverityThreshold}" />
          <Button Classes="tonal"
                  Content="⚙ Filter…"
                  Command="{CompiledBinding EditFilterCommand}" />
          <ToggleButton Content="⏸ Pause"
                        IsChecked="{CompiledBinding IsPaused, Mode=TwoWay}"
                        Background="#1E293B" Foreground="#E2E8F0"
                        Padding="10,4" />
          <Button Classes="tonal"
                  Content="🗑 Clear"
                  Command="{CompiledBinding ClearLogCommand}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ========= Main 3-column body ========= -->
    <Grid Margin="8,4,8,8" ColumnDefinitions="250,*,350">

      <!-- LEFT: event sources -->
      <Border Grid.Column="0" Classes="panel" Padding="8" Margin="0,0,4,0">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock Grid.Row="0"
                     Foreground="{StaticResource LabelDim}"
                     FontWeight="SemiBold" FontSize="12"
                     Margin="0,0,0,4"
                     Text="Event sources" />
          <ListBox Grid.Row="1"
                   ItemsSource="{CompiledBinding EventSources}"
                   Background="Transparent" BorderThickness="0">
            <ListBox.ItemContainerTheme>
              <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                <Setter Property="Padding"   Value="4,2" />
                <Setter Property="MinHeight" Value="22" />
              </ControlTheme>
            </ListBox.ItemContainerTheme>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:EventSourceVm">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0"
                             Text="{CompiledBinding Name}"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"
                             FontSize="12"
                             ToolTip.Tip="{CompiledBinding Name}" />
                  <Button Grid.Column="1"
                          Content="×"
                          Width="22" Padding="0"
                          Background="Transparent" BorderThickness="0"
                          Foreground="#94A3B8"
                          Tag="{CompiledBinding}"
                          Click="OnRemoveSourceClick" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Button Grid.Row="2"
                  Classes="tonal"
                  Content="➕ Add Source"
                  HorizontalAlignment="Stretch"
                  Margin="0,6,0,0"
                  Command="{CompiledBinding AddSourceCommand}" />
        </Grid>
      </Border>

      <!-- CENTER: event log -->
      <Border Grid.Column="1" Classes="panel" Padding="0" Margin="4,0,4,0">
        <Grid RowDefinitions="Auto,*">
          <Grid Grid.Row="0"
                ColumnDefinitions="100,70,160,160,*"
                Background="#121A2C"
                Margin="0" Height="22">
            <TextBlock Grid.Column="0" Classes="colHeader" Text="Time"       Margin="6,4,0,0" />
            <TextBlock Grid.Column="1" Classes="colHeader" Text="Severity"   Margin="0,4,0,0" />
            <TextBlock Grid.Column="2" Classes="colHeader" Text="Source"     Margin="0,4,0,0" />
            <TextBlock Grid.Column="3" Classes="colHeader" Text="EventType"  Margin="0,4,0,0" />
            <TextBlock Grid.Column="4" Classes="colHeader" Text="Message"    Margin="0,4,0,0" />
          </Grid>
          <ListBox Grid.Row="1"
                   ItemsSource="{CompiledBinding Events}"
                   SelectedItem="{CompiledBinding SelectedEntry, Mode=TwoWay}"
                   Background="Transparent" BorderThickness="0">
            <ListBox.ItemContainerTheme>
              <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                <Setter Property="Padding"   Value="0,1" />
                <Setter Property="MinHeight" Value="18" />
              </ControlTheme>
            </ListBox.ItemContainerTheme>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:EventLogEntry">
                <Grid ColumnDefinitions="100,70,160,160,*">
                  <TextBlock Grid.Column="0" Classes="colCell"
                             Text="{CompiledBinding DisplayTime}"
                             Foreground="{CompiledBinding SeverityBrush}"
                             Margin="6,0,0,0" />
                  <TextBlock Grid.Column="1" Classes="colCell"
                             Text="{CompiledBinding Severity}"
                             Foreground="{CompiledBinding SeverityBrush}" />
                  <TextBlock Grid.Column="2" Classes="colCell"
                             Text="{CompiledBinding SourceName}"
                             Foreground="{CompiledBinding SeverityBrush}" />
                  <TextBlock Grid.Column="3" Classes="colCell"
                             Text="{CompiledBinding EventType}"
                             Foreground="{CompiledBinding SeverityBrush}" />
                  <TextBlock Grid.Column="4" Classes="colCell"
                             Text="{CompiledBinding Message}"
                             Foreground="{CompiledBinding SeverityBrush}" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- RIGHT: details TreeView -->
      <Border Grid.Column="2" Classes="panel" Padding="8" Margin="4,0,0,0">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0"
                     Foreground="{StaticResource LabelDim}"
                     FontWeight="SemiBold" FontSize="12"
                     Margin="0,0,0,4"
                     Text="Event details" />
          <TreeView Grid.Row="1"
                    ItemsSource="{CompiledBinding SelectedEntry.FieldRows}"
                    Background="Transparent" BorderThickness="0">
            <TreeView.ItemTemplate>
              <TreeDataTemplate x:DataType="vm:EventFieldDisplay" ItemsSource="{x:Null}">
                <Grid ColumnDefinitions="140,*">
                  <TextBlock Grid.Column="0"
                             Text="{CompiledBinding Path}"
                             FontFamily="Cascadia Mono, Consolas, monospace"
                             FontSize="11"
                             Foreground="#94A3B8"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="1"
                             Text="{CompiledBinding Display}"
                             FontFamily="Cascadia Mono, Consolas, monospace"
                             FontSize="11"
                             Foreground="#E2E8F0"
                             VerticalAlignment="Center"
                             TextWrapping="Wrap" />
                </Grid>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
      </Border>
    </Grid>
  </DockPanel>
</UserControl>

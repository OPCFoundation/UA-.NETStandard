<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UaLens.Plugins.Historian.AnnotationEditDialog"
        Title="Edit annotation"
        Width="560" Height="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}">
  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" ColumnDefinitions="180,*">
    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
               Margin="0,0,0,12"
               TextWrapping="Wrap"
               Text="Edit the annotation Message for the selected history row. The UserName and AnnotationTime fields are auto-populated with the current user and UTC time on Save, per OPC UA Part 11 §5.4.5." />

    <TextBlock Grid.Row="1" Grid.Column="0" Text="Source timestamp (UTC)" VerticalAlignment="Center" />
    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TimestampLabel"
               FontFamily="Cascadia Mono, Consolas, monospace" />

    <TextBlock Grid.Row="2" Grid.Column="0" Text="UserName (auto)" VerticalAlignment="Center" Margin="0,8,0,0" />
    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="UserNameLabel"
               FontFamily="Cascadia Mono, Consolas, monospace" Margin="0,8,0,0" />

    <TextBlock Grid.Row="3" Grid.Column="0" Text="AnnotationTime (auto)" VerticalAlignment="Center" Margin="0,8,0,0" />
    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="AnnotationTimeLabel"
               FontFamily="Cascadia Mono, Consolas, monospace" Margin="0,8,0,0" />

    <TextBlock Grid.Row="4" Grid.Column="0" Text="Message" VerticalAlignment="Top" Margin="0,12,0,0" />
    <TextBox   Grid.Row="4" Grid.Column="1" Grid.RowSpan="2" x:Name="MessageText"
               Margin="0,12,0,0" AcceptsReturn="True" TextWrapping="Wrap"
               MinHeight="120" />

    <TextBlock Grid.Row="6" Grid.ColumnSpan="2" x:Name="ResultLabel" Margin="0,8,0,0"
               FontFamily="Cascadia Mono, Consolas, monospace" TextWrapping="Wrap"
               Foreground="{DynamicResource AccentYellow}" />

    <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="OkButton"     Content="Save"   IsDefault="True" Width="100" />
      <Button x:Name="CancelButton" Content="Cancel" IsCancel="True"  Width="100" Margin="8,0,0,0" />
    </StackPanel>
  </Grid>
</Window>

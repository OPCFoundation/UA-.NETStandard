<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="using:UaLens.Views"
        xmlns:vm="using:UaLens.Plugins.Historian"
        x:Class="UaLens.Plugins.Historian.HistoryUpdateDialog"
        x:DataType="vm:HistorianPlugin"
        Title="History update"
        Width="440"
        SizeToContent="Height"
        MinHeight="240"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0">
  <Window.Styles>
    <Style Selector="TextBlock.h">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#94A3B8" />
    </Style>
    <Style Selector="TextBlock.statDim">
      <Setter Property="Foreground" Value="#94A3B8" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="#1E293B" />
      <Setter Property="Foreground" Value="#E2E8F0" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="100" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0EA5E9" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="100" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </Window.Styles>

  <Grid Margin="16" RowDefinitions="*,Auto">

    <!-- Each editor row sits on its own line and is left-aligned;
         conditional rows collapse via IsVisible. The bottom Execute /
         Close strip is anchored at the dialog footer per dialog
         convention. -->
    <ScrollViewer Grid.Row="0"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Orientation="Vertical" Spacing="10" HorizontalAlignment="Stretch">

        <!-- History update op picker -->
        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Stretch">
          <TextBlock Classes="h" Text="HISTORY UPDATE" />
          <ComboBox ItemsSource="{CompiledBinding UpdateOpOptions}"
                    SelectedIndex="{CompiledBinding SelectedUpdateOpIndex, Mode=TwoWay}"
                    MinWidth="240" HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Single-row ops (Insert / InsertReplace / Replace) -->
        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Stretch"
                    IsVisible="{CompiledBinding IsSingleValueOp}">
          <TextBlock Classes="statDim" Text="Timestamp (UTC):" />
          <v:UtcDateTimePicker Value="{CompiledBinding UpdateTimestamp, Mode=TwoWay}"
                               HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Stretch"
                    IsVisible="{CompiledBinding IsSingleValueOp}">
          <TextBlock Classes="statDim" Text="Value (double):" />
          <TextBox Text="{CompiledBinding UpdateValueText, Mode=TwoWay}"
                   MinWidth="240" HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Single-timestamp op (Remove) -->
        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Stretch"
                    IsVisible="{CompiledBinding IsRemoveOp}">
          <TextBlock Classes="statDim" Text="Timestamp (UTC):" />
          <v:UtcDateTimePicker Value="{CompiledBinding UpdateTimestamp, Mode=TwoWay}"
                               HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Range ops (DeleteRaw / DeleteModified) -->
        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Stretch"
                    IsVisible="{CompiledBinding IsRangeOp}">
          <TextBlock Classes="statDim" Text="Start (UTC):" />
          <v:UtcDateTimePicker Value="{CompiledBinding UpdateStart, Mode=TwoWay}"
                               HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Stretch"
                    IsVisible="{CompiledBinding IsRangeOp}">
          <TextBlock Classes="statDim" Text="End (UTC):" />
          <v:UtcDateTimePicker Value="{CompiledBinding UpdateEnd, Mode=TwoWay}"
                               HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Multi-timestamp op (DeleteAtTime) -->
        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Stretch"
                    IsVisible="{CompiledBinding IsDeleteAtTimeOp}">
          <TextBlock Classes="statDim" Text="Timestamps:" />
          <Border BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4"
                  Background="#0B1220" Padding="4" MinHeight="80">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{CompiledBinding UpdateAtTimes}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="vm:AtTimeRow">
                    <Panel Margin="4">
                      <Border IsVisible="{CompiledBinding IsEditor}"
                              Padding="4" CornerRadius="4" Background="#0F172A"
                              BorderBrush="#1E293B" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                          <v:UtcDateTimePicker Value="{CompiledBinding Timestamp, Mode=TwoWay}" />
                          <Button Classes="tonal" Content="✓"
                                  MinWidth="32" Padding="4,2"
                                  ToolTip.Tip="Confirm"
                                  Command="{CompiledBinding ConfirmCommand}" />
                        </StackPanel>
                      </Border>
                      <Border IsVisible="{CompiledBinding IsLabel}"
                              Padding="6,4" CornerRadius="4" Background="#0F172A"
                              BorderBrush="#1E293B" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                          <TextBlock Text="{CompiledBinding Timestamp, StringFormat='{}{0:yyyy-MM-ddTHH:mm:ssZ}'}"
                                     FontFamily="Cascadia Mono, Consolas, monospace"
                                     FontSize="11"
                                     VerticalAlignment="Center" />
                          <Button Classes="tonal" Content="✗"
                                  MinWidth="28" Padding="4,2"
                                  ToolTip.Tip="Remove"
                                  Command="{CompiledBinding RemoveCommand}" />
                        </StackPanel>
                      </Border>
                      <Button IsVisible="{CompiledBinding IsAddButton}"
                              Classes="tonal" Content="＋"
                              MinWidth="36" Padding="6,4"
                              ToolTip.Tip="Add timestamp"
                              Command="{CompiledBinding RemoveCommand}" />
                    </Panel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </StackPanel>

        <!-- Last-run status -->
        <TextBlock Classes="statDim"
                   FontFamily="Cascadia Mono, Consolas, monospace"
                   TextWrapping="Wrap"
                   Text="{CompiledBinding UpdateResult}" />
      </StackPanel>
    </ScrollViewer>

    <!-- Footer: Execute (primary) + Close (cancel). Anchored at the
         dialog bottom per common dialog convention. -->
    <StackPanel Grid.Row="1" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Classes="primary" Content="Execute"
              IsDefault="True" Width="120"
              Command="{CompiledBinding ExecuteUpdateCommand}" />
      <Button x:Name="CloseButton" Content="Close"
              IsCancel="True" Width="100" Margin="8,0,0,0" />
    </StackPanel>
  </Grid>
</Window>

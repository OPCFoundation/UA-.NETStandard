<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="using:UaLens.Views"
        xmlns:vm="using:UaLens.Plugins.Historian"
        x:Class="UaLens.Plugins.Historian.HistoryUpdateDialog"
        x:DataType="vm:HistorianPlugin"
        Title="History update"
        Width="680" Height="380"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0">
  <Window.Styles>
    <Style Selector="TextBlock.h">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#94A3B8" />
    </Style>
    <Style Selector="TextBlock.statDim">
      <Setter Property="Foreground" Value="#94A3B8" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="#1E293B" />
      <Setter Property="Foreground" Value="#E2E8F0" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="100" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0EA5E9" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="100" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </Window.Styles>

  <Grid Margin="14" RowDefinitions="Auto,*,Auto">

    <!-- Op chooser + Execute -->
    <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="6">
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <TextBlock Classes="h" Text="HISTORY UPDATE" VerticalAlignment="Center" Margin="0,0,8,0" />
        <ComboBox ItemsSource="{CompiledBinding UpdateOpOptions}"
                  SelectedIndex="{CompiledBinding SelectedUpdateOpIndex, Mode=TwoWay}"
                  MinWidth="200" />
        <Button Classes="primary" Content="Execute"
                Command="{CompiledBinding ExecuteUpdateCommand}"
                VerticalAlignment="Center" />
      </StackPanel>

      <!-- Single-row ops (Insert / InsertReplace / Replace) -->
      <StackPanel Orientation="Horizontal" Spacing="6"
                  IsVisible="{CompiledBinding IsSingleValueOp}">
        <TextBlock Classes="statDim" Text="Timestamp (UTC):" VerticalAlignment="Center" Width="110" />
        <v:UtcDateTimePicker Value="{CompiledBinding UpdateTimestamp, Mode=TwoWay}" />
        <TextBlock Classes="statDim" Text="Value (double):" VerticalAlignment="Center" Margin="12,0,0,0" />
        <TextBox Text="{CompiledBinding UpdateValueText, Mode=TwoWay}" MinWidth="160" />
      </StackPanel>

      <!-- Single-timestamp ops (Remove) -->
      <StackPanel Orientation="Horizontal" Spacing="6"
                  IsVisible="{CompiledBinding IsRemoveOp}">
        <TextBlock Classes="statDim" Text="Timestamp (UTC):" VerticalAlignment="Center" Width="110" />
        <v:UtcDateTimePicker Value="{CompiledBinding UpdateTimestamp, Mode=TwoWay}" />
      </StackPanel>

      <!-- Range ops (DeleteRaw / DeleteModified) -->
      <StackPanel Orientation="Horizontal" Spacing="6"
                  IsVisible="{CompiledBinding IsRangeOp}">
        <TextBlock Classes="statDim" Text="Start (UTC):" VerticalAlignment="Center" Width="110" />
        <v:UtcDateTimePicker Value="{CompiledBinding UpdateStart, Mode=TwoWay}" />
        <TextBlock Classes="statDim" Text="End (UTC):" VerticalAlignment="Center" Margin="12,0,0,0" />
        <v:UtcDateTimePicker Value="{CompiledBinding UpdateEnd, Mode=TwoWay}" />
      </StackPanel>
    </StackPanel>

    <!-- Multi-timestamp op (DeleteAtTime) + Result text -->
    <Grid Grid.Row="1" RowDefinitions="*,Auto" Margin="0,8,0,0">
      <Border Grid.Row="0"
              IsVisible="{CompiledBinding IsDeleteAtTimeOp}"
              BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4"
              Background="#0B1220">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{CompiledBinding UpdateAtTimes}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:AtTimeRow">
                <Panel Margin="4">
                  <Border IsVisible="{CompiledBinding IsEditor}"
                          Padding="4" CornerRadius="4" Background="#0F172A"
                          BorderBrush="#1E293B" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                      <v:UtcDateTimePicker Value="{CompiledBinding Timestamp, Mode=TwoWay}" />
                      <Button Classes="tonal" Content="✓"
                              MinWidth="32" Padding="4,2"
                              ToolTip.Tip="Confirm"
                              Command="{CompiledBinding ConfirmCommand}" />
                    </StackPanel>
                  </Border>
                  <Border IsVisible="{CompiledBinding IsLabel}"
                          Padding="6,4" CornerRadius="4" Background="#0F172A"
                          BorderBrush="#1E293B" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                      <TextBlock Text="{CompiledBinding Timestamp, StringFormat='{}{0:yyyy-MM-ddTHH:mm:ssZ}'}"
                                 FontFamily="Cascadia Mono, Consolas, monospace"
                                 FontSize="11"
                                 VerticalAlignment="Center" />
                      <Button Classes="tonal" Content="✗"
                              MinWidth="28" Padding="4,2"
                              ToolTip.Tip="Remove"
                              Command="{CompiledBinding RemoveCommand}" />
                    </StackPanel>
                  </Border>
                  <Button IsVisible="{CompiledBinding IsAddButton}"
                          Classes="tonal" Content="＋"
                          MinWidth="36" Padding="6,4"
                          ToolTip.Tip="Add timestamp"
                          Command="{CompiledBinding RemoveCommand}" />
                </Panel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <TextBlock Grid.Row="1" Classes="statDim"
                 Margin="0,8,0,0"
                 FontFamily="Cascadia Mono, Consolas, monospace"
                 TextWrapping="Wrap"
                 Text="{CompiledBinding UpdateResult}" />
    </Grid>

    <!-- Close -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="CloseButton" Content="Close" IsCancel="True" Width="100" />
    </StackPanel>
  </Grid>
</Window>

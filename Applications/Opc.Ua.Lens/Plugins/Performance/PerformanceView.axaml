<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ScottPlot="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
             xmlns:vm="using:UaLens.Plugins.Performance"
             x:Class="UaLens.Plugins.Performance.PerformanceView"
             x:DataType="vm:PerformancePlugin">
  <UserControl.Styles>
    <Style Selector="TextBlock.h">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#94A3B8" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>
    <Style Selector="TextBlock.stat">
      <Setter Property="Foreground" Value="#E2E8F0" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.statDim">
      <Setter Property="Foreground" Value="#94A3B8" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="#1E293B" />
      <Setter Property="Foreground" Value="#E2E8F0" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="86" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0EA5E9" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="86" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#EF4444" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="86" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.runRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="6,3" />
    </Style>
    <Style Selector="Border.runRow.highlight">
      <Setter Property="Background" Value="#0E2A47" />
      <Setter Property="BorderBrush" Value="#0EA5E9" />
      <Setter Property="BorderThickness" Value="2,0,0,1" />
    </Style>
  </UserControl.Styles>

  <Border Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4" Padding="10">
    <Grid RowDefinitions="Auto,Auto,*,*,Auto,Auto">

      <!-- Row 0: action toolbar (WrapPanel — wraps on narrow windows) -->
      <Border Grid.Row="0" Padding="10" Background="#0B1220" BorderBrush="#1E293B"
              BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,Auto">
          <WrapPanel Grid.Row="0" Orientation="Horizontal" ItemHeight="32">
            <ComboBox x:Name="ModeCombo" Margin="0,0,6,0"
                      ItemsSource="{CompiledBinding ModeOptions}"
                      SelectedItem="{CompiledBinding Mode, Mode=TwoWay}"
                      MinWidth="100" VerticalAlignment="Center" />
            <Button Classes="tonal" Content="Pick target…" Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Command="{CompiledBinding PickTargetCommand}" />
            <Button Classes="primary" Content="▶ Run"  Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Command="{CompiledBinding RunCommand}" />
            <Button Classes="danger"  Content="■ Stop" Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Command="{CompiledBinding StopCommand}" />
            <Button Classes="tonal"   Content="↺ Reset" Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Command="{CompiledBinding ResetCommand}" />
            <Button Classes="tonal"   Content="💾 Save…" Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Save the run history to a CSV file."
                    Command="{CompiledBinding SaveResultsCommand}" />
            <Button Classes="tonal"   Content="📂 Load…" Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Replace the run history with rows loaded from a CSV file."
                    Command="{CompiledBinding LoadResultsCommand}" />
            <Button Classes="tonal"   Content="⚙ Settings…"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Open the workload editor (rate / duration / value generator)."
                    Command="{CompiledBinding OpenSettingsDialogCommand}" />
          </WrapPanel>
          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8"
                      Margin="0,8,0,0" VerticalAlignment="Center">
            <TextBlock Classes="h" Text="TARGET" VerticalAlignment="Center" />
            <TextBlock Classes="statDim" VerticalAlignment="Center"
                       Text="{CompiledBinding TargetNodeIdText}"
                       ToolTip.Tip="{CompiledBinding TargetDescription}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Classes="statDim" Margin="12,0,0,0" VerticalAlignment="Center"
                       Text="·" />
            <TextBlock Classes="statDim" VerticalAlignment="Center"
                       Text="{CompiledBinding TargetDescription}"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="420" />
            <TextBlock Classes="statDim" Margin="12,0,0,0" VerticalAlignment="Center"
                       Text="·" />
            <TextBlock Classes="statDim" VerticalAlignment="Center"
                       Text="{CompiledBinding EffectiveDurationText, StringFormat='duration={0}'}" />
            <TextBlock Classes="statDim" Margin="12,0,0,0" VerticalAlignment="Center"
                       Text="·" />
            <TextBlock Classes="statDim" VerticalAlignment="Center"
                       Text="{CompiledBinding ConcurrencyHint}" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Row 1: throughput chart heading -->
      <TextBlock Grid.Row="1" Classes="h" Margin="2,10,2,4"
                 Text="THROUGHPUT — rolling 60 s window (ops/sec)" />

      <!-- Row 2: throughput chart -->
      <Border Grid.Row="2" Background="#0B1220" BorderBrush="#1E293B"
              BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
        <ScottPlot:AvaPlot x:Name="ThroughputPlot" />
      </Border>

      <!-- Row 3: latency histogram -->
      <Border Grid.Row="3" Background="#0B1220" BorderBrush="#1E293B"
              BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" Classes="h" Margin="8,6,0,0"
                     Text="LATENCY HISTOGRAM — log buckets, vertical lines mark p50 / p95 / p99" />
          <ScottPlot:AvaPlot Grid.Row="1" x:Name="HistogramPlot" />
        </Grid>
      </Border>

      <!-- Row 4: stats footer -->
      <Border Grid.Row="4" Padding="8,6" Margin="0,8,0,0"
              Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4">
        <Grid ColumnDefinitions="*,*,*,*,*,*,*">
          <StackPanel Grid.Column="0" Orientation="Vertical">
            <TextBlock Classes="statDim" Text="TOTAL OPS" />
            <TextBlock Classes="stat" Text="{CompiledBinding TotalOpsText}" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Vertical">
            <TextBlock Classes="statDim" Text="MEAN OPS/S" />
            <TextBlock Classes="stat" Text="{CompiledBinding MeanRateText}" />
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Vertical">
            <TextBlock Classes="statDim" Text="p50 (ms)" />
            <TextBlock Classes="stat" Text="{CompiledBinding P50Text}" />
          </StackPanel>
          <StackPanel Grid.Column="3" Orientation="Vertical">
            <TextBlock Classes="statDim" Text="p95 (ms)" />
            <TextBlock Classes="stat" Text="{CompiledBinding P95Text}" />
          </StackPanel>
          <StackPanel Grid.Column="4" Orientation="Vertical">
            <TextBlock Classes="statDim" Text="p99 (ms)" />
            <TextBlock Classes="stat" Text="{CompiledBinding P99Text}" />
          </StackPanel>
          <StackPanel Grid.Column="5" Orientation="Vertical">
            <TextBlock Classes="statDim" Text="MAX (ms)" />
            <TextBlock Classes="stat" Text="{CompiledBinding MaxLatencyText}" />
          </StackPanel>
          <StackPanel Grid.Column="6" Orientation="Vertical">
            <TextBlock Classes="statDim" Text="ERRORS" />
            <TextBlock Classes="stat" Text="{CompiledBinding ErrorsText}" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Row 5: run history list + compare-last-3 toggle -->
      <Border Grid.Row="5" Padding="8,6" Margin="0,8,0,0"
              Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,Auto,Auto">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Classes="h" VerticalAlignment="Center"
                       Text="RUNS — most recent first; toggle 'Compare last 3' to highlight the three latest rows" />
            <CheckBox Grid.Column="1" Content="Compare last 3"
                      VerticalAlignment="Center"
                      IsChecked="{CompiledBinding CompareLast3, Mode=TwoWay}" />
          </Grid>
          <TextBlock Grid.Row="1" Classes="statDim" Margin="0,2,0,4"
                     Text="{CompiledBinding CompareStatus}" />
          <ListBox Grid.Row="2" x:Name="HistoryList"
                   ItemsSource="{CompiledBinding RunHistory}"
                   MaxHeight="160"
                   Background="#0F172A"
                   BorderBrush="#1E293B"
                   BorderThickness="1">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:BenchmarkRunRow">
                <Border Classes="runRow" Classes.highlight="{CompiledBinding IsHighlighted}">
                  <Grid ColumnDefinitions="160,90,90,100,80,80,70">
                    <TextBlock Grid.Column="0" Classes="stat" Text="{CompiledBinding TimestampDisplay}" />
                    <TextBlock Grid.Column="1" Classes="statDim" TextAlignment="Right"
                               Text="{CompiledBinding TargetRateDisplay}" />
                    <TextBlock Grid.Column="2" Classes="stat" TextAlignment="Right"
                               Text="{CompiledBinding AchievedRateDisplay}" />
                    <TextBlock Grid.Column="3" Classes="statDim" TextAlignment="Right"
                               Text="{CompiledBinding TotalOpsDisplay}" />
                    <TextBlock Grid.Column="4" Classes="statDim" TextAlignment="Right"
                               Text="{CompiledBinding P50Display}" />
                    <TextBlock Grid.Column="5" Classes="statDim" TextAlignment="Right"
                               Text="{CompiledBinding P99Display}" />
                    <TextBlock Grid.Column="6" Classes="statDim" TextAlignment="Right"
                               Text="{CompiledBinding ErrorCountDisplay}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>

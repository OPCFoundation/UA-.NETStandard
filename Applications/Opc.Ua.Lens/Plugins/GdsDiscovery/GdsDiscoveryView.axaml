<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UaLens.Plugins.GdsDiscovery"
             x:Class="UaLens.Plugins.GdsDiscovery.GdsDiscoveryView"
             x:DataType="vm:GdsDiscoveryPlugin"
             Background="{DynamicResource SurfaceBg}" Foreground="{DynamicResource TextPrimary}">
  <UserControl.Styles>
    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="{DynamicResource SeparatorBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="96" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource AccentBlue}" />
      <Setter Property="Foreground" Value="{DynamicResource AppBg}" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{DynamicResource PanelBg}" />
    </Style>
    <Style Selector="TextBlock.h">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
    </Style>
    <Style Selector="TextBlock.row">
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
  </UserControl.Styles>

  <DockPanel LastChildFill="True">

    <Border DockPanel.Dock="Top" Classes="panel" Margin="8,8,8,4" Padding="8,6">
      <WrapPanel Classes="toolbar" Orientation="Horizontal" ItemHeight="32">
        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,4,0" VerticalAlignment="Center">
          <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" FontSize="11"
                     Text="LDS host:" />
          <TextBox Width="220"
                   Text="{CompiledBinding LocalMachineUrl, Mode=TwoWay}"
                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12" />
        </StackPanel>
        <Button Classes="tonal" Content="Add Custom…" Margin="0,0,4,0"
                Command="{CompiledBinding AddCustomEndpointCommand}" />
        <Button Classes="tonal" Content="★ Favourite" Margin="0,0,4,0"
                ToolTip.Tip="Save the selected endpoint as a favourite"
                Command="{CompiledBinding AddCurrentToFavouritesCommand}" />
        <Button Classes="tonal" Content="✕ Unfavourite" Margin="0,0,4,0"
                ToolTip.Tip="Remove the selected ⭐ favourite under Custom Discovery"
                Command="{CompiledBinding RemoveFromFavouritesCommand}" />
        <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,6" />
        <Button Classes="tonal" Content="↻ Refresh" Margin="0,0,4,0"
                Command="{CompiledBinding RefreshSelectedRootCommand}" />
        <Button Classes="tonal" Content="Filter…" Margin="0,0,4,0"
                Command="{CompiledBinding EditFilterCommand}" />
        <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,6" />
        <Button Classes="primary" Content="Connect" Margin="0,0,4,0"
                Command="{CompiledBinding ConnectSelectedToConnectionPaneCommand}" />
      </WrapPanel>
    </Border>

    <Border Classes="panel" Margin="8,4,8,8">
      <Grid ColumnDefinitions="*,5,2*">
        <!-- Left: tree -->
        <Grid Grid.Column="0" RowDefinitions="Auto,*">
          <Border Grid.Row="0" Background="{DynamicResource SeparatorBrush}">
            <TextBlock Margin="8,4" Classes="h" Text="SERVERS" />
          </Border>
          <TreeView Grid.Row="1"
                    ItemsSource="{CompiledBinding Roots}"
                    SelectedItem="{CompiledBinding SelectedNode, Mode=TwoWay}"
                    Background="{DynamicResource PanelBg}" Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="0">
            <TreeView.Styles>
              <Style Selector="TreeViewItem" x:DataType="vm:DiscoveryNode">
                <Setter Property="IsExpanded" Value="{CompiledBinding IsExpanded, Mode=TwoWay}" />
                <Setter Property="Padding" Value="4,2" />
              </Style>
            </TreeView.Styles>
            <TreeView.ItemTemplate>
              <TreeDataTemplate DataType="vm:DiscoveryNode" ItemsSource="{CompiledBinding Children}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="{CompiledBinding Glyph}"
                             FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12" />
                  <TextBlock Text="{CompiledBinding Display}" Classes="row" />
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      Background="{DynamicResource SeparatorBrush}" />

        <!-- Right: endpoints list with resizable columns. -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*" Grid.IsSharedSizeScope="True">
          <Grid Grid.Row="0" Background="{DynamicResource SeparatorBrush}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*"   SharedSizeGroup="DiCol0" />
              <ColumnDefinition Width="Auto" SharedSizeGroup="DiSep0" />
              <ColumnDefinition Width="120"  SharedSizeGroup="DiCol1" />
              <ColumnDefinition Width="Auto" SharedSizeGroup="DiSep1" />
              <ColumnDefinition Width="*"    SharedSizeGroup="DiCol2" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Margin="8,4" Classes="h" Text="ENDPOINT URL" />
            <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource AppBg}"
                          ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" />
            <TextBlock Grid.Column="2" Margin="8,4" Classes="h" Text="SEC. MODE" />
            <GridSplitter Grid.Column="3" Width="4" Background="{DynamicResource AppBg}"
                          ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" />
            <TextBlock Grid.Column="4" Margin="8,4" Classes="h" Text="PROFILE" />
          </Grid>
          <ListBox Grid.Row="1"
                   ItemsSource="{CompiledBinding Endpoints}"
                   SelectedItem="{CompiledBinding SelectedEndpoint, Mode=TwoWay}"
                   Background="{DynamicResource PanelBg}" Foreground="{DynamicResource TextPrimary}"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:DiscoveryEndpointRow">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"   SharedSizeGroup="DiCol0" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="DiSep0" />
                    <ColumnDefinition Width="120"  SharedSizeGroup="DiCol1" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="DiSep1" />
                    <ColumnDefinition Width="*"    SharedSizeGroup="DiCol2" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{CompiledBinding Url}" Classes="row" />
                  <TextBlock Grid.Column="2" Text="{CompiledBinding SecurityMode}" Classes="row" />
                  <TextBlock Grid.Column="4" Text="{CompiledBinding SecurityProfile}" Classes="row" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Grid>
    </Border>
  </DockPanel>
</UserControl>

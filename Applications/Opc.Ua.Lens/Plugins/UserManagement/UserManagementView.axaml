<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UaLens.Plugins.UserManagement"
             x:Class="UaLens.Plugins.UserManagement.UserManagementView"
             x:DataType="vm:UserManagementPlugin"
             Background="{DynamicResource SurfaceBg}" Foreground="{DynamicResource TextPrimary}">

  <UserControl.Styles>
    <Style Selector="Border.panel">
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{DynamicResource PanelBg}" />
    </Style>
    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="{DynamicResource SeparatorBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="92" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource AccentBlue}" />
      <Setter Property="Foreground" Value="{DynamicResource AppBg}" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.statusbar">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBlock.restrictions">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.colhdr">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
    </Style>
    <Style Selector="TextBlock.row">
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
  </UserControl.Styles>

  <DockPanel LastChildFill="True">

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top" Classes="panel" Margin="8,8,8,4" Padding="8,6">
      <WrapPanel Classes="toolbar" Orientation="Horizontal" ItemHeight="32">
        <Button Classes="tonal" Content="↻ Refresh" Margin="0,0,4,0"
                Command="{CompiledBinding RefreshCommand}" />
        <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,6" />
        <Button Classes="tonal" Content="＋ Add user…" Margin="0,0,4,0"
                Command="{CompiledBinding AddUserCommand}" />
        <Button Classes="tonal" Content="✎ Modify…" Margin="0,0,4,0"
                Command="{CompiledBinding ModifyUserCommand}"
                CommandParameter="{CompiledBinding SelectedUser}" />
        <Button Classes="tonal" Content="🗑 Remove" Margin="0,0,4,0"
                Command="{CompiledBinding RemoveUserCommand}"
                CommandParameter="{CompiledBinding SelectedUser}" />
        <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,6" />
        <Button Classes="tonal" Content="🔑 Change password…" Margin="0,0,4,0"
                Command="{CompiledBinding ChangePasswordCommand}"
                ToolTip.Tip="Change the password of the currently-authenticated session user." />
      </WrapPanel>
    </Border>

    <!-- Status bar at bottom -->
    <Border DockPanel.Dock="Bottom" Classes="panel" Margin="8,4,8,8" Padding="8,4">
      <TextBlock Classes="statusbar" Text="{CompiledBinding Status}" />
    </Border>

    <!-- Body: ListBox above with shared-size grid header, password restrictions below -->
    <Border Classes="panel" Margin="8,4,8,4">
      <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0" RowDefinitions="Auto,*" Grid.IsSharedSizeScope="True">
          <!-- Column header row -->
          <Grid Grid.Row="0" Background="{DynamicResource SeparatorBrush}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="220" SharedSizeGroup="UmCol0" />
              <ColumnDefinition Width="Auto" SharedSizeGroup="UmSep0" />
              <ColumnDefinition Width="100" SharedSizeGroup="UmCol1" />
              <ColumnDefinition Width="Auto" SharedSizeGroup="UmSep1" />
              <ColumnDefinition Width="2*"  SharedSizeGroup="UmCol2" />
              <ColumnDefinition Width="Auto" SharedSizeGroup="UmSep2" />
              <ColumnDefinition Width="3*"  SharedSizeGroup="UmCol3" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Margin="8,4" Classes="colhdr" Text="USER NAME" />
            <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource AppBg}"
                          ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" />
            <TextBlock Grid.Column="2" Margin="8,4" Classes="colhdr" Text="STATE" />
            <GridSplitter Grid.Column="3" Width="4" Background="{DynamicResource AppBg}"
                          ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" />
            <TextBlock Grid.Column="4" Margin="8,4" Classes="colhdr" Text="FLAGS" />
            <GridSplitter Grid.Column="5" Width="4" Background="{DynamicResource AppBg}"
                          ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" />
            <TextBlock Grid.Column="6" Margin="8,4" Classes="colhdr" Text="DESCRIPTION" />
          </Grid>

          <ListBox Grid.Row="1"
                   x:Name="UsersList"
                   ItemsSource="{CompiledBinding Users}"
                   SelectedItem="{CompiledBinding SelectedUser, Mode=TwoWay}"
                   Background="{DynamicResource PanelBg}" Foreground="{DynamicResource TextPrimary}"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:UserVm">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" SharedSizeGroup="UmCol0" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="UmSep0" />
                    <ColumnDefinition Width="100" SharedSizeGroup="UmCol1" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="UmSep1" />
                    <ColumnDefinition Width="2*"  SharedSizeGroup="UmCol2" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="UmSep2" />
                    <ColumnDefinition Width="3*"  SharedSizeGroup="UmCol3" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{CompiledBinding UserName}"    Classes="row" Margin="8,2" />
                  <TextBlock Grid.Column="2" Text="{CompiledBinding StateText}"   Classes="row" Margin="8,2" />
                  <TextBlock Grid.Column="4" Text="{CompiledBinding FlagsText}"   Classes="row" Margin="8,2" />
                  <TextBlock Grid.Column="6" Text="{CompiledBinding Description}" Classes="row" Margin="8,2" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>

        <Border Grid.Row="1" BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,1,0,0" Padding="10,8"
                Background="{DynamicResource PanelBg}">
          <StackPanel Spacing="2">
            <TextBlock Classes="restrictions" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryAlt}"
                       Text="Password restrictions (server-reported):" />
            <TextBlock Classes="restrictions"
                       Text="{CompiledBinding PasswordRestrictionsText}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </DockPanel>
</UserControl>

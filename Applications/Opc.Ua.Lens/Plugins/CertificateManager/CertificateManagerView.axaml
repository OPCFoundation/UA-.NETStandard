<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UaLens.Plugins.CertificateManager"
             x:Class="UaLens.Plugins.CertificateManager.CertificateManagerView"
             x:DataType="vm:CertificateManagerPlugin"
             Background="#121A2C" Foreground="#E2E8F0">
  <UserControl.Resources>
    <SolidColorBrush x:Key="PanelBg"     Color="#0B1220" />
    <SolidColorBrush x:Key="PanelBorder" Color="#1E293B" />
    <SolidColorBrush x:Key="LabelDim"    Color="#94A3B8" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Border.panel">
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{StaticResource PanelBg}" />
    </Style>
    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="#1E293B" />
      <Setter Property="Foreground" Value="#E2E8F0" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="92" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0EA5E9" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.h">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#94A3B8" />
    </Style>
    <Style Selector="TextBlock.row">
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
  </UserControl.Styles>

  <DockPanel LastChildFill="True">

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top" Classes="panel" Margin="8,8,8,4" Padding="8,6">
      <DockPanel LastChildFill="False">
        <TextBlock VerticalAlignment="Center"
                   Foreground="{StaticResource LabelDim}"
                   FontSize="12" Margin="0,0,12,0"
                   Text="🔑 Certificate Manager" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Button Classes="tonal" Content="＋ Add store…"
                  Command="{CompiledBinding AddStoreCommand}" />
          <Button Classes="tonal" Content="↻ Refresh"
                  Command="{CompiledBinding RefreshCommand}" />
          <Border Width="1" Background="#1E293B" Margin="2,4" />
          <Button Classes="tonal" Content="🛡 Open trust dialog…"
                  Command="{CompiledBinding OpenTrustDialogCommand}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Status -->
    <Border DockPanel.Dock="Bottom" Classes="panel" Margin="8,4,8,8" Padding="8,4">
      <TextBlock Text="{CompiledBinding Status}"
                 Foreground="{StaticResource LabelDim}"
                 FontFamily="Cascadia Mono, Consolas, monospace"
                 FontSize="11" />
    </Border>

    <!-- Body: TreeView (left) + ListBox (right) -->
    <Border Classes="panel" Margin="8,4,8,4">
      <Grid ColumnDefinitions="*,5,2*">

        <!-- Left: stores tree -->
        <Grid Grid.Column="0" RowDefinitions="Auto,*">
          <Border Grid.Row="0" Background="#1E293B">
            <TextBlock Margin="8,4" Classes="h" Text="STORES" />
          </Border>
          <TreeView Grid.Row="1"
                    x:Name="StoresTree"
                    ItemsSource="{CompiledBinding Stores}"
                    SelectedItem="{CompiledBinding SelectedStore, Mode=TwoWay}"
                    Background="#0B1220" Foreground="#E2E8F0"
                    BorderThickness="0">
            <TreeView.ItemTemplate>
              <TreeDataTemplate DataType="vm:CertStoreNode">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="{CompiledBinding Glyph}"
                             FontFamily="Cascadia Mono, Consolas, monospace"
                             FontSize="12"
                             VerticalAlignment="Center" />
                  <TextBlock Text="{CompiledBinding DisplayName}"
                             FontFamily="Cascadia Mono, Consolas, monospace"
                             FontSize="12"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"
                             ToolTip.Tip="{CompiledBinding Description}" />
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      Background="#1E293B" />

        <!-- Right: certificates list -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*">
          <Grid Grid.Row="0" Background="#1E293B"
                ColumnDefinitions="200,2*,2*,110,110,90">
            <TextBlock Grid.Column="0" Margin="8,4" Classes="h" Text="THUMBPRINT" />
            <TextBlock Grid.Column="1" Margin="8,4" Classes="h" Text="SUBJECT" />
            <TextBlock Grid.Column="2" Margin="8,4" Classes="h" Text="ISSUER" />
            <TextBlock Grid.Column="3" Margin="8,4" Classes="h" Text="NOT BEFORE" />
            <TextBlock Grid.Column="4" Margin="8,4" Classes="h" Text="NOT AFTER" />
            <TextBlock Grid.Column="5" Margin="8,4" Classes="h" Text="STATUS" />
          </Grid>
          <ListBox Grid.Row="1"
                   x:Name="CertList"
                   ItemsSource="{CompiledBinding Certificates}"
                   SelectedItem="{CompiledBinding SelectedCertificate, Mode=TwoWay}"
                   Background="#0B1220" Foreground="#E2E8F0"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:CertItemRow">
                <Grid ColumnDefinitions="200,2*,2*,110,110,90"
                      PointerPressed="OnCertRowPointerPressed">
                  <TextBlock Grid.Column="0" Text="{CompiledBinding Thumbprint}" Classes="row" Margin="8,2" />
                  <TextBlock Grid.Column="1" Text="{CompiledBinding Subject}"    Classes="row" Margin="8,2" />
                  <TextBlock Grid.Column="2" Text="{CompiledBinding Issuer}"     Classes="row" Margin="8,2" />
                  <TextBlock Grid.Column="3" Text="{CompiledBinding NotBefore}"  Classes="row" Margin="8,2" />
                  <TextBlock Grid.Column="4" Text="{CompiledBinding NotAfter}"   Classes="row" Margin="8,2" />
                  <TextBlock Grid.Column="5" Text="{CompiledBinding Status}"     Classes="row" Margin="8,2" FontWeight="SemiBold" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Grid>
    </Border>
  </DockPanel>
</UserControl>

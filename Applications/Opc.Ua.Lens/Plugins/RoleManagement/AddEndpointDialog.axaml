<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UaLens.Plugins.RoleManagement.AddEndpointDialog"
        Title="Add endpoint"
        Width="640" Height="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}">
  <Window.Styles>
    <Style Selector="TextBlock.k">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </Window.Styles>

  <DockPanel Margin="16" LastChildFill="True">

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="OkButton" Content="Add" IsDefault="True" Width="100" />
      <Button x:Name="CancelButton" Content="Cancel" IsCancel="True"
              Width="100" Margin="8,0,0,0" />
    </StackPanel>

    <TextBlock x:Name="ErrorLabel" DockPanel.Dock="Bottom"
               Foreground="{DynamicResource AccentRedLight}"
               Margin="0,8,0,0" IsVisible="False" TextWrapping="Wrap" />

    <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">

      <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                 Margin="0,0,0,12"
                 TextWrapping="Wrap"
                 Text="Add an endpoint entry to the role's Endpoints list. EndpointUrl is required; the security mode and policy URI default to None/None for development and should be tightened for production." />

      <TextBlock Grid.Row="1" Grid.Column="0" Classes="k" Text="Endpoint URL *" />
      <TextBox   Grid.Row="1" Grid.Column="1" x:Name="EndpointUrlBox"
                 Watermark="opc.tcp://host:port/path" />

      <TextBlock Grid.Row="2" Grid.Column="0" Classes="k" Text="Security mode" Margin="0,8,0,0" />
      <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="SecurityModeBox" Margin="0,8,0,0"
                 HorizontalAlignment="Stretch" />

      <TextBlock Grid.Row="3" Grid.Column="0" Classes="k" Text="Security policy URI" Margin="0,8,0,0" />
      <TextBox   Grid.Row="3" Grid.Column="1" x:Name="SecurityPolicyBox" Margin="0,8,0,0"
                 Text="http://opcfoundation.org/UA/SecurityPolicy#None" />

      <TextBlock Grid.Row="4" Grid.Column="0" Classes="k" Text="Transport profile URI" Margin="0,8,0,0" />
      <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TransportProfileBox" Margin="0,8,0,0"
                 Text="http://opcfoundation.org/UA-Profile/Transport/uatcp-uasc-uabinary" />
    </Grid>
  </DockPanel>
</Window>

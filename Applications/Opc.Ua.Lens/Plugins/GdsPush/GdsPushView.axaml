<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UaLens.Plugins.GdsPush"
             x:Class="UaLens.Plugins.GdsPush.GdsPushView"
             x:DataType="vm:GdsPushPlugin">
  <UserControl.Styles>
    <Style Selector="Border.panel">
      <Setter Property="BorderBrush" Value="#1E293B" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="10" />
      <Setter Property="Background" Value="#0B1220" />
    </Style>
    <Style Selector="TextBlock.h">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#94A3B8" />
    </Style>
    <Style Selector="TextBlock.k">
      <Setter Property="Foreground" Value="#64748B" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBlock.v">
      <Setter Property="Foreground" Value="#E2E8F0" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="TextWrapping" Value="NoWrap" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="#1E293B" />
      <Setter Property="Foreground" Value="#E2E8F0" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="MinWidth" Value="90" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0EA5E9" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="MinWidth" Value="120" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="10" RowDefinitions="Auto,Auto,*,Auto">

    <!-- Row 0: connection bar — endpoint comes from the main Connection pane
         (read-only here); the Connect/Disconnect buttons drive a SEPARATE
         GDS Push session, often with admin credentials. -->
    <Border Grid.Row="0" Classes="panel" Margin="0,0,0,6">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
        <TextBlock Grid.Column="0" Classes="h" Text="Endpoint" VerticalAlignment="Center" Margin="0,0,8,0" />
        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                   Text="{CompiledBinding EndpointUrl}"
                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                   Foreground="#94A3B8" TextTrimming="CharacterEllipsis" />
        <Button    Grid.Column="2" Classes="primary" Margin="8,0,0,0"
                   Content="{CompiledBinding ConnectButtonText}"
                   Command="{CompiledBinding UseDifferentEndpointCommand}" />
        <Button    Grid.Column="3" Classes="tonal" Margin="8,0,0,0"
                   Content="Disconnect"
                   IsVisible="{CompiledBinding HasSecondarySession}"
                   Command="{CompiledBinding DisconnectCommand}" />
        <TextBlock Grid.Column="4" Margin="12,0,0,0" Classes="v"
                   VerticalAlignment="Center"
                   Text="{CompiledBinding ConnectionStatus}" />
      </Grid>
    </Border>

    <!-- Row 1: server info card -->
    <Border Grid.Row="1" Classes="panel" Margin="0,0,0,6">
      <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Classes="h" Text="Server" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" Grid.Column="0" Classes="k" Text="Application name" Margin="0,2" />
        <TextBlock Grid.Row="1" Grid.Column="1" Classes="v"
                   Text="{CompiledBinding ServerApplicationName}" Margin="0,2" />
        <TextBlock Grid.Row="2" Grid.Column="0" Classes="k" Text="Application URI" Margin="0,2" />
        <TextBlock Grid.Row="2" Grid.Column="1" Classes="v"
                   Text="{CompiledBinding ServerApplicationUri}" Margin="0,2" />
        <Grid     Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*,*,*" Margin="0,4,0,0">
          <StackPanel Grid.Column="0" Orientation="Vertical">
            <TextBlock Classes="k" Text="Cert subject" />
            <TextBlock Classes="v" Text="{CompiledBinding ServerCertSubject}" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,0,0">
            <TextBlock Classes="k" Text="Cert issuer" />
            <TextBlock Classes="v" Text="{CompiledBinding ServerCertIssuer}" />
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Vertical" Margin="8,0,0,0">
            <TextBlock Classes="k" Text="Cert expiry (UTC)" />
            <TextBlock Classes="v" Text="{CompiledBinding ServerCertExpiry}" />
          </StackPanel>
        </Grid>
      </Grid>
    </Border>

    <!-- Row 2: trust-list tabs -->
    <Border Grid.Row="2" Classes="panel">
      <TabControl x:Name="TrustTabs" Background="Transparent" BorderThickness="0" Padding="0">
        <TabItem Header="Trusted Peers" x:Name="TabTrusted">
          <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="200,2*,2*,100,100"
                  Background="#1E293B" Margin="0,4,0,0">
              <TextBlock Grid.Column="0" Margin="6,4" Classes="h" Text="Thumbprint" />
              <TextBlock Grid.Column="1" Margin="6,4" Classes="h" Text="Subject" />
              <TextBlock Grid.Column="2" Margin="6,4" Classes="h" Text="Issuer" />
              <TextBlock Grid.Column="3" Margin="6,4" Classes="h" Text="Not Before" />
              <TextBlock Grid.Column="4" Margin="6,4" Classes="h" Text="Not After" />
            </Grid>
            <ListBox Grid.Row="1" x:Name="TrustedList"
                     ItemsSource="{CompiledBinding Trusted}"
                     Background="#0B1220" Foreground="#E2E8F0"
                     BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:GdsCertItem">
                  <Grid ColumnDefinitions="200,2*,2*,100,100">
                    <TextBlock Grid.Column="0" Margin="6,2"
                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                               Text="{CompiledBinding Thumbprint}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1" Margin="6,2"
                               Text="{CompiledBinding Subject}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2" Margin="6,2"
                               Text="{CompiledBinding Issuer}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3" Margin="6,2"
                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                               Text="{CompiledBinding NotBefore}" />
                    <TextBlock Grid.Column="4" Margin="6,2"
                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                               Text="{CompiledBinding NotAfter}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </TabItem>
        <TabItem Header="Issuers" x:Name="TabIssuer">
          <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="200,2*,2*,100,100"
                  Background="#1E293B" Margin="0,4,0,0">
              <TextBlock Grid.Column="0" Margin="6,4" Classes="h" Text="Thumbprint" />
              <TextBlock Grid.Column="1" Margin="6,4" Classes="h" Text="Subject" />
              <TextBlock Grid.Column="2" Margin="6,4" Classes="h" Text="Issuer" />
              <TextBlock Grid.Column="3" Margin="6,4" Classes="h" Text="Not Before" />
              <TextBlock Grid.Column="4" Margin="6,4" Classes="h" Text="Not After" />
            </Grid>
            <ListBox Grid.Row="1" x:Name="IssuerList"
                     ItemsSource="{CompiledBinding Issuers}"
                     Background="#0B1220" Foreground="#E2E8F0"
                     BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:GdsCertItem">
                  <Grid ColumnDefinitions="200,2*,2*,100,100">
                    <TextBlock Grid.Column="0" Margin="6,2"
                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                               Text="{CompiledBinding Thumbprint}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1" Margin="6,2"
                               Text="{CompiledBinding Subject}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2" Margin="6,2"
                               Text="{CompiledBinding Issuer}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3" Margin="6,2"
                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                               Text="{CompiledBinding NotBefore}" />
                    <TextBlock Grid.Column="4" Margin="6,2"
                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                               Text="{CompiledBinding NotAfter}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </TabItem>
        <TabItem Header="Rejected" x:Name="TabRejected">
          <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="200,2*,2*,100,100"
                  Background="#1E293B" Margin="0,4,0,0">
              <TextBlock Grid.Column="0" Margin="6,4" Classes="h" Text="Thumbprint" />
              <TextBlock Grid.Column="1" Margin="6,4" Classes="h" Text="Subject" />
              <TextBlock Grid.Column="2" Margin="6,4" Classes="h" Text="Issuer" />
              <TextBlock Grid.Column="3" Margin="6,4" Classes="h" Text="Not Before" />
              <TextBlock Grid.Column="4" Margin="6,4" Classes="h" Text="Not After" />
            </Grid>
            <ListBox Grid.Row="1" x:Name="RejectedList"
                     ItemsSource="{CompiledBinding Rejected}"
                     Background="#0B1220" Foreground="#E2E8F0"
                     BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:GdsCertItem">
                  <Grid ColumnDefinitions="200,2*,2*,100,100">
                    <TextBlock Grid.Column="0" Margin="6,2"
                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                               Text="{CompiledBinding Thumbprint}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1" Margin="6,2"
                               Text="{CompiledBinding Subject}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2" Margin="6,2"
                               Text="{CompiledBinding Issuer}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3" Margin="6,2"
                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                               Text="{CompiledBinding NotBefore}" />
                    <TextBlock Grid.Column="4" Margin="6,2"
                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                               Text="{CompiledBinding NotAfter}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </TabItem>
      </TabControl>
    </Border>

    <!-- Row 3: action bar -->
    <Border Grid.Row="3" Classes="panel" Margin="0,6,0,0">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <Button Classes="tonal" Content="↻ Refresh"
                IsEnabled="{CompiledBinding !IsBusy}"
                Command="{CompiledBinding RefreshCommand}" />
        <Button Classes="tonal" Content="+ Add Cert…"
                IsEnabled="{CompiledBinding !IsBusy}"
                Command="{CompiledBinding AddCertificateCommand}" />
        <Button Classes="tonal" Content="− Remove Cert"
                IsEnabled="{CompiledBinding !IsBusy}"
                Command="{CompiledBinding RemoveCertificateCommand}" />
        <Button Classes="tonal" Content="🔑 Request New Cert…"
                IsEnabled="{CompiledBinding !IsBusy}"
                Command="{CompiledBinding RequestNewCertificateCommand}" />
        <Button Classes="primary" Content="✓ Apply Changes"
                IsEnabled="{CompiledBinding !IsBusy}"
                Command="{CompiledBinding ApplyChangesCommand}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UaLens.Plugins.GdsManagement.RegisterApplicationDialog"
        Title="Register application"
        Width="760" Height="780"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0">
  <Window.Styles>
    <Style Selector="TextBlock.k">
      <Setter Property="Foreground" Value="#94A3B8" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.section">
      <Setter Property="Foreground" Value="#CBD5E1" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Margin" Value="0,12,0,4" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </Window.Styles>

  <DockPanel Margin="16" LastChildFill="True">

    <!-- Bottom command bar -->
    <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0" ColumnDefinitions="*,Auto">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
        <Button x:Name="LoadButton" Content="Load from config…" />
        <Button x:Name="SaveButton" Content="Save…" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="OkButton"     Content="Register" IsDefault="True" Width="120" />
        <Button x:Name="CancelButton" Content="Cancel"   IsCancel="True"  Width="100" Margin="8,0,0,0" />
      </StackPanel>
    </Grid>

    <TextBlock x:Name="ErrorLabel" DockPanel.Dock="Bottom"
               Foreground="#F87171" Margin="0,8,0,0" IsVisible="False" TextWrapping="Wrap" />

    <!-- Scrollable body -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0">

        <TextBlock Margin="0,0,0,12" TextWrapping="Wrap"
                   Text="Register a new application with the connected Global Discovery Server. Required fields are marked." />

        <!-- Registration type -->
        <Grid ColumnDefinitions="180,*" RowDefinitions="Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Classes="k" Text="_Registration type *" />
          <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="RegistrationTypeBox" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="ClientPull" />
            <ComboBoxItem Content="ServerPull" />
            <ComboBoxItem Content="ServerPush" />
          </ComboBox>
        </Grid>

        <!-- Common fields -->
        <TextBlock Classes="section" Text="Common" />
        <Grid ColumnDefinitions="180,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto">

          <TextBlock Grid.Row="0" Grid.Column="0" Classes="k" Text="Application Name *" />
          <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NameBox" />

          <TextBlock Grid.Row="1" Grid.Column="0" Classes="k" Text="Application URI *" Margin="0,8,0,0" />
          <TextBox   Grid.Row="1" Grid.Column="1" x:Name="UriBox" Margin="0,8,0,0"
                     Watermark="urn:hostname:product" />

          <TextBlock Grid.Row="2" Grid.Column="0" Classes="k" Text="Product URI *" Margin="0,8,0,0" />
          <TextBox   Grid.Row="2" Grid.Column="1" x:Name="ProductUriBox" Margin="0,8,0,0"
                     Watermark="urn:vendor:product" />

          <TextBlock Grid.Row="3" Grid.Column="0" Classes="k" Text="Discovery URLs" Margin="0,8,0,0" VerticalAlignment="Top" />
          <TextBox   Grid.Row="3" Grid.Column="1" x:Name="DiscoveryBox" Margin="0,8,0,0"
                     AcceptsReturn="True" Height="80"
                     Watermark="One URL per line (e.g. opc.tcp://host:port/...)" />

          <TextBlock Grid.Row="4" Grid.Column="0" Classes="k" Text="Server Capabilities" Margin="0,8,0,0" VerticalAlignment="Top" />
          <TextBox   Grid.Row="4" Grid.Column="1" x:Name="CapabilitiesBox" Margin="0,8,0,0"
                     AcceptsReturn="True" Height="60"
                     Watermark="Comma- or newline-separated (e.g. DA, HA, LDS)" />
        </Grid>

        <!-- Pull-mode-only fields (Client/Server Pull) -->
        <StackPanel x:Name="PullPanel" Spacing="0">

          <TextBlock Classes="section" Text="Certificates (Pull)" />
          <Grid ColumnDefinitions="180,*"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">

            <TextBlock Grid.Row="0" Grid.Column="0" Classes="k" Text="Cert store path" />
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="CertStorePathBox"
                       Watermark="%CommonApplicationData%\OPC Foundation\..." />

            <TextBlock Grid.Row="1" Grid.Column="0" Classes="k" Text="Subject name" Margin="0,8,0,0" />
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="SubjectNameBox" Margin="0,8,0,0"
                       Watermark="CN=MyApp, O=OPC Foundation, …" />

            <TextBlock Grid.Row="2" Grid.Column="0" Classes="k" Text="Public-key file" Margin="0,8,0,0" />
            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="PublicKeyPathBox" Margin="0,8,0,0"
                       Watermark="path\to\app.cer / app.pem" />

            <TextBlock Grid.Row="3" Grid.Column="0" Classes="k" Text="Private-key file" Margin="0,8,0,0" />
            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="PrivateKeyPathBox" Margin="0,8,0,0"
                       Watermark="path\to\app.pfx / app.pem" />

            <TextBlock Grid.Row="4" Grid.Column="0" Classes="k" Text="Trust-list store" Margin="0,8,0,0" />
            <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TrustListStorePathBox" Margin="0,8,0,0" />

            <TextBlock Grid.Row="5" Grid.Column="0" Classes="k" Text="Issuer-list store" Margin="0,8,0,0" />
            <TextBox   Grid.Row="5" Grid.Column="1" x:Name="IssuerListStorePathBox" Margin="0,8,0,0" />

            <TextBlock Grid.Row="6" Grid.Column="0" Classes="k" Text="Domains (SANs)" Margin="0,8,0,0" />
            <TextBox   Grid.Row="6" Grid.Column="1" x:Name="DomainsBox" Margin="0,8,0,0"
                       Watermark="comma-separated DNS names / IPs" />
          </Grid>

          <Expander x:Name="HttpsExpander" Header="HTTPS" Margin="0,12,0,0">
            <Grid ColumnDefinitions="180,*"
                  RowDefinitions="Auto,Auto,Auto,Auto">

              <TextBlock Grid.Row="0" Grid.Column="0" Classes="k" Text="HTTPS public-key" />
              <TextBox   Grid.Row="0" Grid.Column="1" x:Name="HttpsPublicKeyPathBox" />

              <TextBlock Grid.Row="1" Grid.Column="0" Classes="k" Text="HTTPS private-key" Margin="0,8,0,0" />
              <TextBox   Grid.Row="1" Grid.Column="1" x:Name="HttpsPrivateKeyPathBox" Margin="0,8,0,0" />

              <TextBlock Grid.Row="2" Grid.Column="0" Classes="k" Text="HTTPS trust-list" Margin="0,8,0,0" />
              <TextBox   Grid.Row="2" Grid.Column="1" x:Name="HttpsTrustListStorePathBox" Margin="0,8,0,0" />

              <TextBlock Grid.Row="3" Grid.Column="0" Classes="k" Text="HTTPS issuer-list" Margin="0,8,0,0" />
              <TextBox   Grid.Row="3" Grid.Column="1" x:Name="HttpsIssuerListStorePathBox" Margin="0,8,0,0" />
            </Grid>
          </Expander>
        </StackPanel>

        <!-- Push-mode-only fields -->
        <StackPanel x:Name="PushPanel" Spacing="0" IsVisible="False">
          <TextBlock Classes="section" Text="Push endpoint" />
          <Grid ColumnDefinitions="180,*,Auto" RowDefinitions="Auto,Auto">

            <TextBlock Grid.Row="0" Grid.Column="0" Classes="k" Text="Push endpoint URL" />
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="PushEndpointUrlBox"
                       Watermark="opc.tcp://host:port/path" />
            <Button    Grid.Row="0" Grid.Column="2" x:Name="PickEndpointButton"
                       Content="Pick…" Margin="8,0,0,0" />

            <TextBlock Grid.Row="1" Grid.Column="0" Classes="k" Text="Security" Margin="0,8,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PushSecurityLabel" Margin="0,8,0,0"
                       Foreground="#94A3B8"
                       Text="(not picked — Sign &amp; Encrypt will be auto-selected if you skip)" />
          </Grid>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>

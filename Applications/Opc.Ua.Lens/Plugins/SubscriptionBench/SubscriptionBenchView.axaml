<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ScottPlot="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
             xmlns:vm="using:UaLens.Plugins.SubscriptionBench"
             x:Class="UaLens.Plugins.SubscriptionBench.SubscriptionBenchView"
             x:DataType="vm:SubscriptionBenchPlugin">
  <UserControl.Styles>
    <Style Selector="TextBlock.h">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
      <Setter Property="Margin" Value="0,4,0,2" />
    </Style>
    <Style Selector="TextBlock.stat">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.statDim">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="{DynamicResource SeparatorBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="120" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource AccentBlue}" />
      <Setter Property="Foreground" Value="{DynamicResource AppBg}" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="86" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="{DynamicResource AccentRed}" />
      <Setter Property="Foreground" Value="{DynamicResource AppBg}" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="86" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.sep">
      <Setter Property="Width" Value="1" />
      <Setter Property="Margin" Value="6,4" />
      <Setter Property="Background" Value="{DynamicResource SeparatorBrush}" />
    </Style>
  </UserControl.Styles>

  <Border Background="{DynamicResource AppBg}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="4" Padding="10">
    <DockPanel>

      <!-- Top: action toolbar -->
      <Border DockPanel.Dock="Top" Padding="10"
              Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource PanelBorder}"
              BorderThickness="1" CornerRadius="4">
        <WrapPanel Classes="toolbar" Orientation="Horizontal" ItemHeight="32">
          <Button Classes="tonal" Content="🔎 Pick variables…" Margin="0,0,6,0"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Open a flat browser, multi-pick Variable nodes to add to the pool."
                  Command="{CompiledBinding PickVariablesCommand}" />
          <Button Classes="tonal" Content="🌲 Pick subtree…" Margin="0,0,6,0"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Pick a starting node; every Variable below it is appended to the pool."
                  Command="{CompiledBinding PickSubtreeCommand}" />
          <TextBlock VerticalAlignment="Center" Classes="statDim" Margin="6,0"
                     Text="{CompiledBinding PoolDescription}" />
          <Button Classes="tonal" Content="🗑 Clear pool" Margin="0,0,6,0"
                  VerticalAlignment="Center"
                  Command="{CompiledBinding ClearPoolCommand}" />
          <Border Classes="sep" />
          <Button Classes="danger" Content="■ Stop" Margin="0,0,6,0"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Zero both sliders and tear every subscription down."
                  Command="{CompiledBinding StopCommand}" />
          <Button Classes="tonal" Content="🗑 Clear counters" Margin="0,0,6,0"
                  VerticalAlignment="Center"
                  Command="{CompiledBinding ClearCommand}" />
        </WrapPanel>
      </Border>

      <!-- Subscriptions slider row -->
      <Border DockPanel.Dock="Top" Padding="10,8" Margin="0,8,0,0"
              Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource PanelBorder}"
              BorderThickness="1" CornerRadius="4">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <TextBlock Grid.Column="0" Classes="h"
                     Text="Subscriptions:"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0" />
          <Slider Grid.Column="1"
                  Minimum="0"
                  Maximum="{CompiledBinding SubsSliderMax}"
                  Value="{CompiledBinding SubsSliderValue, Mode=TwoWay}"
                  IsEnabled="{CompiledBinding CanResize}"
                  TickFrequency="1"
                  ToolTip.Tip="Number of subscriptions created on the session. Subscriptions are torn down when reduced." />
          <TextBlock Grid.Column="2" Classes="stat"
                     Text="{CompiledBinding SubsSizeText}"
                     VerticalAlignment="Center"
                     Margin="12,0,0,0" />
        </Grid>
      </Border>

      <!-- Items-per-subscription slider row -->
      <Border DockPanel.Dock="Top" Padding="10,8" Margin="0,8,0,0"
              Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource PanelBorder}"
              BorderThickness="1" CornerRadius="4">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <TextBlock Grid.Column="0" Classes="h"
                     Text="Items per sub:"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0" />
          <Slider Grid.Column="1"
                  Minimum="0"
                  Maximum="{CompiledBinding ItemsSliderMax}"
                  Value="{CompiledBinding ItemsSliderValue, Mode=TwoWay}"
                  IsEnabled="{CompiledBinding CanResize}"
                  TickFrequency="100"
                  ToolTip.Tip="Monitored items per subscription. Each sub fills slots 0..N-1 from the pool round-robin." />
          <TextBlock Grid.Column="2" Classes="stat"
                     Text="{CompiledBinding ItemsSizeText}"
                     VerticalAlignment="Center"
                     Margin="12,0,0,0" />
        </Grid>
      </Border>

      <!-- Body: chart left, stats right -->
      <Grid Margin="0,8,0,0" ColumnDefinitions="*,5,360">
        <Border Grid.Column="0"
                Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1" CornerRadius="4">
          <ScottPlot:AvaPlot x:Name="Chart" />
        </Border>
        <GridSplitter Grid.Column="1"
                      Background="{DynamicResource SeparatorBrush}"
                      ResizeDirection="Columns" />
        <Border Grid.Column="2" Padding="8"
                Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1" CornerRadius="4">
          <ScrollViewer>
            <StackPanel Spacing="4">
              <TextBlock Classes="h" Text="THROUGHPUT" />
              <TextBlock Classes="stat" Text="{CompiledBinding Stats1sText}" />
              <TextBlock Classes="stat" Text="{CompiledBinding Stats10sText}" />
              <TextBlock Classes="stat" Text="{CompiledBinding Stats30sText}" />
              <TextBlock Classes="stat" Text="{CompiledBinding Stats60sText}" />

              <TextBlock Classes="h" Text="TOTALS" />
              <TextBlock Classes="stat" Text="{CompiledBinding TotalValuesText}" />
              <TextBlock Classes="stat" Text="{CompiledBinding TotalErrorsText}" />
              <TextBlock Classes="stat" Text="{CompiledBinding PublishIntervalText}" />

              <TextBlock Classes="h" Text="ENGINE" />
              <TextBlock Foreground="{DynamicResource TextPrimary}"
                         FontFamily="Cascadia Mono, Consolas, monospace"
                         FontSize="11"
                         Text="{CompiledBinding EngineMetricsText}" />
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

    </DockPanel>
  </Border>
</UserControl>

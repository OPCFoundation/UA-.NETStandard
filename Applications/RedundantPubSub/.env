# Default environment for Applications/RedundantPubSub/docker-compose.yml.
# docker compose auto-loads this file from the compose file directory.

# strong = three named Raft publishers + one subscriber; demo = single-container in-process failover.
COMPOSE_PROFILES=strong

# PubSub redundancy mode: hot keeps SequenceNumber checkpoints; cold demonstrates reset on failover; warm is paused standby without hot checkpoints.
HA_MODE=hot

# Demo posture only. Set HA_RECORD_KEY to a shared base64 32-byte key and remove this for production-like runs.
HA_INSECURE=true

# UDP multicast endpoint shared by publishers and subscriber inside the compose bridge network.
PUBSUB_ENDPOINT=opc.udp://239.0.0.1:4840

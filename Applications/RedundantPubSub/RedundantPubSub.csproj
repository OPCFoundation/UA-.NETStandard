<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework Condition="'$(CustomTestTarget)' == ''">net10.0</TargetFramework>
    <TargetFramework Condition="'$(CustomTestTarget)' != ''">$(CustomTestTarget)</TargetFramework>
    <OutputType>Exe</OutputType>
    <AssemblyName>RedundantPubSub</AssemblyName>
    <PackageId>RedundantPubSub</PackageId>
    <Company>OPC Foundation</Company>
    <Description>OPC UA PubSub active/standby high-availability sample with SequenceNumber continuity.</Description>
    <Copyright>Copyright © 2004-2026 OPC Foundation, Inc</Copyright>
    <RootNamespace>RedundantPubSub</RootNamespace>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <PublishAot>true</PublishAot>
    <RestrictForLegacyTfm>true</RestrictForLegacyTfm>

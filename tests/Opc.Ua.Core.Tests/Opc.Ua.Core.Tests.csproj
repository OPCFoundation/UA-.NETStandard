<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>$(TestsTargetFrameworks)</TargetFrameworks>
    <RootNamespace>Opc.Ua.Core.Tests</RootNamespace>
    <GenerateProgramFile>false</GenerateProgramFile>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" PrivateAssets="all" />
    <PackageReference Include="Moq" />
    <PackageReference Include="NUnit" />
    <PackageReference Include="NUnit.Console" />
    <PackageReference Include="NUnit.Analyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="NUnit3TestAdapter">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="System.IO.Compression" />
    <PackageReference Include="System.Private.Uri" />
  </ItemGroup>
  <ItemGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net8.0'))">
    <!-- SharedKestrelHostTests uses HostBuilder which is in Microsoft.Extensions.Hosting.
         The Opc.Ua.Bindings.Https reference normally pulls this in transitively through
         the FrameworkReference Microsoft.AspNetCore.App, but only when Bindings.Https
         is built for net8+. When CustomTestTarget=netstandard2.1 the binding is built
         as netstandard2.1 (downlevel Kestrel packages, no FrameworkReference) while
         the tests still build at net8.0 — adding the package explicitly here covers
         both matrix entries with one reference. -->
    <PackageReference Include="Microsoft.Extensions.Hosting" />
  </ItemGroup>
  <PropertyGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net8.0')) AND ('$(CustomTestTarget)' == '' OR '$(CustomTestTarget)' == 'net8.0' OR '$(CustomTestTarget)' == 'net9.0' OR '$(CustomTestTarget)' == 'net10.0')">
    <DefineConstants>$(DefineConstants);HAS_KESTREL_TCP_LISTENER</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(NetStandardTests)' == 'true'">
    <DefineConstants>$(DefineConstants);NET_STANDARD_TESTS</DefineConstants>
  </PropertyGroup>
  <ItemGroup Condition="'$(SignAssembly)' != 'true'">
    <PackageReference Include="EmbedIO" />
  </ItemGroup>
  <PropertyGroup Condition="'$(SignAssembly)' != 'true'">
    <DefineConstants>$(DefineConstants);EMBED_IO_INCLUDED</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\Common\Main.cs" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="Security\Certificates\Assets\Test_chain.pem">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Opc.Ua.Gds.Common\Opc.Ua.Gds.Common.csproj" />
    <ProjectReference Include="..\..\src\Opc.Ua.Core\Opc.Ua.Core.csproj" />
    <ProjectReference Include="..\..\src\Opc.Ua.Bindings.Https\Opc.Ua.Bindings.Https.csproj" />
    <ProjectReference Include="..\Opc.Ua.Security.Certificates.Tests\Opc.Ua.Security.Certificates.Tests.csproj" />
    <ProjectReference Include="..\Opc.Ua.Core.TestFramework\Opc.Ua.Core.TestFramework.csproj" />
    <ProjectReference Include="..\Opc.Ua.Test.Common\Opc.Ua.Test.Common.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Update="Security\Certificates\CertificateStoreTypeTestConfig.xml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>

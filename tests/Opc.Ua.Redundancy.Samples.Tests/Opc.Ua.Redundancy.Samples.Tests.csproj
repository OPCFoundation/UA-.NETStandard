<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!--
      These are process-level integration tests that launch the RedundantServer,
      RedundantClient and RedundantPubSub sample applications (which target
      net10.0 only) and assert on their high-availability log output. The tests
      are therefore net10.0 only. The project also exposes a net48 placeholder
      target with no test code so Azure DevOps can restore/build the project
      with CustomTestTarget=net48 and subsequently invoke `dotnet test -f
      net48` without that property. Other legacy per-TFM matrix entries map to
      the same placeholder target.
    -->
    <TargetFrameworks Condition="'$(CustomTestTarget)' == ''">net48;net10.0</TargetFrameworks>
    <TargetFrameworks Condition="'$(CustomTestTarget)' == 'net10.0'">net10.0</TargetFrameworks>
    <TargetFrameworks Condition="'$(CustomTestTarget)' != '' AND '$(CustomTestTarget)' != 'net10.0'">net48</TargetFrameworks>
    <_SamplesPlaceholder Condition="'$(TargetFramework)' == 'net48'">true</_SamplesPlaceholder>
    <EnableDefaultCompileItems Condition="'$(_SamplesPlaceholder)' == 'true'">false</EnableDefaultCompileItems>
    <RootNamespace>Opc.Ua.Redundancy.Samples.Tests</RootNamespace>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!--
      The placeholder assembly (legacy TFM matrix entries) has no source code;
      suppress CA1014 (assembly-level CLSCompliant) for that build only.
    -->
    <NoWarn Condition="'$(_SamplesPlaceholder)' == 'true'">$(NoWarn);CA1014</NoWarn>
    <!--
      Common test-project suppression list (matches the rest of tests/*/*.csproj).
      Test code is allowed to be noisier on these analyzer rules.
    -->
    <NoWarn>$(NoWarn);RCS0056;RCS1166;RCS1174;RCS1229;RCS1047;RCS1077;NUnit2023;NUnit2010;NUnit2045</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="NUnit" />
    <PackageReference Include="NUnit.Analyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="NUnit3TestAdapter">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup Condition="'$(_SamplesPlaceholder)' == 'true'">
    <Compile Include="PlaceholderTests.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(_SamplesPlaceholder)' != 'true'">
    <Compile Remove="PlaceholderTests.cs" />
  </ItemGroup>

  <!--
    Reference the sample applications so they are built alongside these tests and
    can be located and launched at runtime. ReferenceOutputAssembly is false
    because the tests launch the apps as external processes rather than calling
    into their assemblies directly.
  -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <ProjectReference Include="..\..\samples\RedundantServer\RedundantServer.csproj"
                      ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\samples\RedundantClient\RedundantClient.csproj"
                      ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\samples\RedundantPubSub\RedundantPubSub.csproj"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!--
      Stress/chaos tests rely on modern primitives (Task.Delay TimeProvider
      overloads, RandomNumberGenerator.GetInt32, Math.Clamp,
      ValueTask.CompletedTask, IClientChannelManager.ReconnectAsync(budget))
      that do not exist on net48/net472. When CustomTestTarget is unset
      (e.g. CodeQL whole-solution build) restrict to the supported TFMs.
      When CustomTestTarget is set to a modern .NET TFM the standard
      TestsTargetFrameworks pipeline takes over so the matrix can still
      drive a single TFM. When CustomTestTarget is set to net4x or
      netstandard2.0 the project still has to build (the CI matrix
      restores+tests every **/*.Tests.csproj for that TFM combination),
      so produce a placeholder assembly with no test code: the per-TFM
      test command then discovers zero tests, exits cleanly, and the
      matrix succeeds. The stress tests themselves still run on the
      net8.0/net9.0/net10.0 matrix entries where they are supported.
    -->
    <_StressTestSupportedTarget>false</_StressTestSupportedTarget>
    <_StressTestSupportedTarget Condition="'$(CustomTestTarget)' == ''">true</_StressTestSupportedTarget>
    <_StressTestSupportedTarget Condition="'$(CustomTestTarget)' == 'net8.0'">true</_StressTestSupportedTarget>
    <_StressTestSupportedTarget Condition="'$(CustomTestTarget)' == 'net9.0'">true</_StressTestSupportedTarget>
    <_StressTestSupportedTarget Condition="'$(CustomTestTarget)' == 'net10.0'">true</_StressTestSupportedTarget>
    <_StressTestSupportedTarget Condition="'$(CustomTestTarget)' == 'netstandard2.1'">true</_StressTestSupportedTarget>
    <TargetFrameworks Condition="'$(_StressTestSupportedTarget)' == 'true' AND '$(CustomTestTarget)' == ''">net8.0;net9.0;net10.0</TargetFrameworks>
    <TargetFrameworks Condition="'$(_StressTestSupportedTarget)' == 'true' AND '$(CustomTestTarget)' != ''">$(TestsTargetFrameworks)</TargetFrameworks>
    <!--
      For incompatible matrix entries (net48 / net472 / netstandard2.0) the
      project compiles against net8.0 as a placeholder that contains no test
      sources. The matrix step still runs dotnet test against the resulting
      assembly; NUnit discovers zero tests and exits cleanly.
    -->
    <TargetFrameworks Condition="'$(_StressTestSupportedTarget)' != 'true'">net8.0</TargetFrameworks>
    <EnableDefaultCompileItems Condition="'$(_StressTestSupportedTarget)' != 'true'">false</EnableDefaultCompileItems>
    <!--
      The placeholder assembly compiled for net48/net472/netstandard2.0
      matrix entries has no source code; suppress CA1014 (assembly-level
      CLSCompliant) for that build only — the real stress-test build on
      net8.0+ keeps the warning enabled.
    -->
    <NoWarn Condition="'$(_StressTestSupportedTarget)' != 'true'">$(NoWarn);CA1014</NoWarn>
    <RootNamespace>Opc.Ua.Stress.Tests</RootNamespace>
    <GenerateProgramFile>false</GenerateProgramFile>
    <Nullable>enable</Nullable>
    <!--
      Common test-project suppression list (matches the rest of Tests/*/*.csproj).
      Test code is allowed to be noisier on these analyzer rules.
    -->
    <NoWarn>$(NoWarn);RCS0056;RCS1166;RCS1174;RCS1229;RCS1047;RCS1077;NUnit2023;NUnit2010;NUnit2045</NoWarn>
  </PropertyGroup>
  <PropertyGroup Condition="'$(NetStandardTests)' == 'true'">
    <DefineConstants>$(DefineConstants);NET_STANDARD_TESTS</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="NUnit" />
    <PackageReference Include="NUnit.Console" />
    <PackageReference Include="NUnit.Analyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="NUnit3TestAdapter">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Moq" />
    <PackageReference Include="Microsoft.Bcl.TimeProvider" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" PrivateAssets="all" />
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Common\Main.cs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Client\Opc.Ua.Client.csproj" />
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Configuration\Opc.Ua.Configuration.csproj" />
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Server\Opc.Ua.Server.csproj" />
    <ProjectReference Include="..\..\Applications\Quickstarts.Servers\Quickstarts.Servers.csproj" />
    <ProjectReference Include="..\Opc.Ua.Client.TestFramework\Opc.Ua.Client.TestFramework.csproj" />
    <ProjectReference Include="..\Opc.Ua.Server.TestFramework\Opc.Ua.Server.TestFramework.csproj" />
    <ProjectReference Include="..\Opc.Ua.Test.Common\Opc.Ua.Test.Common.csproj" />
  </ItemGroup>
</Project>

<?xml version="1.0" encoding="utf-8"?>
<ApplicationConfiguration
  xmlns="http://opcfoundation.org/UA/SDK/Configuration.xsd"
  xmlns:ua="http://opcfoundation.org/UA/2008/02/Types.xsd">
  <ApplicationName>Full Server Test</ApplicationName>
  <ApplicationUri>urn:localhost:fullservertest</ApplicationUri>
  <ProductUri>http://test.org/fullserver</ProductUri>
  <ApplicationType>Server_0</ApplicationType>
  <SecurityConfiguration>
    <ApplicationCertificate>
      <StoreType>Directory</StoreType>
      <StorePath>%LocalApplicationData%/OPC/fullserver</StorePath>
      <SubjectName>CN=FullServer, O=Test</SubjectName>
    </ApplicationCertificate>
    <TrustedIssuerCertificates>
      <StoreType>Directory</StoreType>
      <StorePath>%LocalApplicationData%/OPC/issuers</StorePath>
    </TrustedIssuerCertificates>
    <TrustedPeerCertificates>
      <StoreType>Directory</StoreType>
      <StorePath>%LocalApplicationData%/OPC/trusted</StorePath>
    </TrustedPeerCertificates>
    <NonceLength>32</NonceLength>
    <RejectSHA1SignedCertificates>true</RejectSHA1SignedCertificates>
    <MinimumCertificateKeySize>2048</MinimumCertificateKeySize>
  </SecurityConfiguration>
  <ServerConfiguration>
    <BaseAddresses>
      <ua:String>opc.tcp://localhost:4840</ua:String>
      <ua:String>https://localhost:4843</ua:String>
    </BaseAddresses>
    <AlternateBaseAddresses>
      <ua:String>opc.tcp://myhost:4840</ua:String>
    </AlternateBaseAddresses>
    <SecurityPolicies>
      <ServerSecurityPolicy>
        <SecurityMode>SignAndEncrypt_3</SecurityMode>
        <SecurityPolicyUri>http://opcfoundation.org/UA/SecurityPolicy#Basic256Sha256</SecurityPolicyUri>
      </ServerSecurityPolicy>
      <ServerSecurityPolicy>
        <SecurityMode>Sign_2</SecurityMode>
        <SecurityPolicyUri>http://opcfoundation.org/UA/SecurityPolicy#Aes128_Sha256_RsaOaep</SecurityPolicyUri>
      </ServerSecurityPolicy>
    </SecurityPolicies>
    <MinRequestThreadCount>5</MinRequestThreadCount>
    <MaxRequestThreadCount>50</MaxRequestThreadCount>
    <MaxQueuedRequestCount>500</MaxQueuedRequestCount>
    <UserTokenPolicies>
      <ua:UserTokenPolicy>
        <ua:TokenType>Anonymous_0</ua:TokenType>
      </ua:UserTokenPolicy>
      <ua:UserTokenPolicy>
        <ua:TokenType>UserName_1</ua:TokenType>
      </ua:UserTokenPolicy>
    </UserTokenPolicies>
    <DiagnosticsEnabled>true</DiagnosticsEnabled>
    <MaxSessionCount>200</MaxSessionCount>
    <MaxChannelCount>500</MaxChannelCount>
    <MinSessionTimeout>5000</MinSessionTimeout>
    <MaxSessionTimeout>1800000</MaxSessionTimeout>
    <MaxBrowseContinuationPoints>20</MaxBrowseContinuationPoints>
    <MaxQueryContinuationPoints>15</MaxQueryContinuationPoints>
    <MaxHistoryContinuationPoints>50</MaxHistoryContinuationPoints>
    <MaxRequestAge>300000</MaxRequestAge>
    <MinPublishingInterval>50</MinPublishingInterval>
    <MaxPublishingInterval>1800000</MaxPublishingInterval>
    <PublishingResolution>50</PublishingResolution>
    <MaxSubscriptionLifetime>1800000</MaxSubscriptionLifetime>
    <MaxMessageQueueSize>20</MaxMessageQueueSize>
    <AvailableSamplingRates>
      <SamplingRateGroup>
        <Start>5</Start>
        <Increment>5</Increment>
        <Count>20</Count>
      </SamplingRateGroup>
      <SamplingRateGroup>
        <Start>100</Start>
        <Increment>100</Increment>
        <Count>4</Count>
      </SamplingRateGroup>
    </AvailableSamplingRates>
    <MaxNotificationQueueSize>200</MaxNotificationQueueSize>
    <MaxNotificationsPerPublish>500</MaxNotificationsPerPublish>
    <MinMetadataSamplingInterval>2000</MinMetadataSamplingInterval>
    <MaxRegistrationInterval>60000</MaxRegistrationInterval>
    <MinSubscriptionLifetime>5000</MinSubscriptionLifetime>
    <MaxPublishRequestCount>50</MaxPublishRequestCount>
    <MaxSubscriptionCount>200</MaxSubscriptionCount>
    <MaxEventQueueSize>5000</MaxEventQueueSize>
    <ServerProfileArray>
      <ua:String>http://opcfoundation.org/UA-Profile/Server/StandardUA2017</ua:String>
      <ua:String>http://opcfoundation.org/UA-Profile/Server/DataAccess</ua:String>
    </ServerProfileArray>
    <ShutdownDelay>10</ShutdownDelay>
    <ServerCapabilities>
      <ua:String>DA</ua:String>
      <ua:String>HD</ua:String>
    </ServerCapabilities>
    <SupportedPrivateKeyFormats>
      <ua:String>PFX</ua:String>
      <ua:String>PEM</ua:String>
    </SupportedPrivateKeyFormats>
    <MaxTrustListSize>65536</MaxTrustListSize>
    <MultiCastDnsEnabled>true</MultiCastDnsEnabled>
    <ReverseConnect>
      <Clients>
        <ReverseConnectClient>
          <EndpointUrl>opc.tcp://client1:65300</EndpointUrl>
          <Timeout>5000</Timeout>
          <MaxSessionCount>10</MaxSessionCount>
          <Enabled>true</Enabled>
        </ReverseConnectClient>
        <ReverseConnectClient>
          <EndpointUrl>opc.tcp://client2:65301</EndpointUrl>
          <Timeout>10000</Timeout>
          <MaxSessionCount>5</MaxSessionCount>
          <Enabled>false</Enabled>
        </ReverseConnectClient>
      </Clients>
      <ConnectInterval>20000</ConnectInterval>
      <ConnectTimeout>45000</ConnectTimeout>
      <RejectTimeout>90000</RejectTimeout>
    </ReverseConnect>
    <OperationLimits>
      <MaxNodesPerRead>1000</MaxNodesPerRead>
      <MaxNodesPerHistoryReadData>500</MaxNodesPerHistoryReadData>
      <MaxNodesPerHistoryReadEvents>500</MaxNodesPerHistoryReadEvents>
      <MaxNodesPerWrite>1000</MaxNodesPerWrite>
      <MaxNodesPerHistoryUpdateData>200</MaxNodesPerHistoryUpdateData>
      <MaxNodesPerHistoryUpdateEvents>200</MaxNodesPerHistoryUpdateEvents>
      <MaxNodesPerMethodCall>100</MaxNodesPerMethodCall>
      <MaxNodesPerBrowse>2000</MaxNodesPerBrowse>
      <MaxNodesPerRegisterNodes>1500</MaxNodesPerRegisterNodes>
      <MaxNodesPerTranslateBrowsePathsToNodeIds>1500</MaxNodesPerTranslateBrowsePathsToNodeIds>
      <MaxNodesPerNodeManagement>500</MaxNodesPerNodeManagement>
      <MaxMonitoredItemsPerCall>3000</MaxMonitoredItemsPerCall>
    </OperationLimits>
    <AuditingEnabled>true</AuditingEnabled>
    <HttpsMutualTls>true</HttpsMutualTls>
    <DurableSubscriptionsEnabled>true</DurableSubscriptionsEnabled>
    <MaxDurableNotificationQueueSize>100000</MaxDurableNotificationQueueSize>
    <MaxDurableEventQueueSize>50000</MaxDurableEventQueueSize>
    <MaxDurableSubscriptionLifetimeInHours>24</MaxDurableSubscriptionLifetimeInHours>
  </ServerConfiguration>
</ApplicationConfiguration>

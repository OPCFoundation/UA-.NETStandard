<?xml version="1.0" encoding="utf-8"?>
<ConfiguredEndpointCollection xmlns="http://opcfoundation.org/UA/SDK/Configuration.xsd"
  xmlns:ua="http://opcfoundation.org/UA/2008/02/Types.xsd">
  <KnownHosts>
    <ua:String>localhost</ua:String>
    <ua:String>192.168.1.100</ua:String>
  </KnownHosts>
  <Endpoints>
    <ConfiguredEndpoint>
      <Endpoint>
        <ua:EndpointUrl>opc.tcp://localhost:4840</ua:EndpointUrl>
        <ua:SecurityMode>SignAndEncrypt_3</ua:SecurityMode>
        <ua:SecurityPolicyUri>http://opcfoundation.org/UA/SecurityPolicy#Basic256Sha256</ua:SecurityPolicyUri>
      </Endpoint>
      <UpdateBeforeConnect>true</UpdateBeforeConnect>
      <BinaryEncodingSupport>Optional</BinaryEncodingSupport>
      <SelectedUserTokenPolicy>0</SelectedUserTokenPolicy>
    </ConfiguredEndpoint>
    <ConfiguredEndpoint>
      <Endpoint>
        <ua:EndpointUrl>https://192.168.1.100:4843</ua:EndpointUrl>
        <ua:SecurityMode>None_1</ua:SecurityMode>
        <ua:SecurityPolicyUri>http://opcfoundation.org/UA/SecurityPolicy#None</ua:SecurityPolicyUri>
      </Endpoint>
      <UpdateBeforeConnect>false</UpdateBeforeConnect>
      <BinaryEncodingSupport>Required</BinaryEncodingSupport>
      <SelectedUserTokenPolicy>1</SelectedUserTokenPolicy>
      <ReverseConnect>
        <Enabled>true</Enabled>
        <ServerUri>urn:server:example</ServerUri>
        <Thumbprint>AABBCCDDEEFF00112233</Thumbprint>
      </ReverseConnect>
    </ConfiguredEndpoint>
    <ConfiguredEndpoint>
      <Endpoint>
        <ua:EndpointUrl>opc.tcp://localhost:4841</ua:EndpointUrl>
        <ua:SecurityMode>Sign_2</ua:SecurityMode>
        <ua:SecurityPolicyUri>http://opcfoundation.org/UA/SecurityPolicy#Aes128_Sha256_RsaOaep</ua:SecurityPolicyUri>
      </Endpoint>
      <UpdateBeforeConnect>true</UpdateBeforeConnect>
      <BinaryEncodingSupport>None</BinaryEncodingSupport>
      <SelectedUserTokenPolicy>2</SelectedUserTokenPolicy>
    </ConfiguredEndpoint>
  </Endpoints>
  <TcpProxyUrl>opc.tcp://proxy.example.com:4840</TcpProxyUrl>
</ConfiguredEndpointCollection>

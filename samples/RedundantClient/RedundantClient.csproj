<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework Condition="'$(CustomTestTarget)' == ''">net10.0</TargetFramework>
    <TargetFramework Condition="'$(CustomTestTarget)' != ''">$(CustomTestTarget)</TargetFramework>
    <OutputType>Exe</OutputType>
    <AssemblyName>RedundantClient</AssemblyName>
    <PackageId>RedundantClient</PackageId>
    <Company>OPC Foundation</Company>
    <Description>OPC UA non-transparent redundant managed client sample.</Description>
    <Copyright>Copyright © 2004-2025 OPC Foundation, Inc</Copyright>
    <RootNamespace>RedundantClient</RootNamespace>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <PublishAot>true</PublishAot>
    <RestrictForLegacyTfm>true</RestrictForLegacyTfm>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="RaftCs.Transport.NanoMsg" />
    <PackageReference Include="System.CommandLine" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Stack\Opc.Ua.Core\Opc.Ua.Core.csproj" />
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Configuration\Opc.Ua.Configuration.csproj" />
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Client\Opc.Ua.Client.csproj" />
    <ProjectReference Include="..\..\Libraries\Opc.Ua.Redundancy.Client\Opc.Ua.Redundancy.Client.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Update="RedundantClient.Config.xml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>

# Default environment for samples/RedundantClient/docker-compose.yml.
#
# docker compose auto-loads this file from the compose file's directory (even when you run
# from the repository root with -f samples/RedundantClient/docker-compose.yml). It sets
# the DEFAULT matrix cell — eventual servers + independent clients — so a bare `up` just
# works. Override any value on the command line (host env wins over this file), e.g.:
#
#   COMPOSE_PROFILES=server-strong,client-coordinated CLIENT_CONSISTENCY=strong \
#     docker compose -f samples/RedundantClient/docker-compose.yml up --build

# Which matrix cell to run: one server profile + one client profile.
#   server-eventual | server-strong   and   client-independent | client-coordinated
COMPOSE_PROFILES=server-eventual,client-independent

# Coordinated client shared-store flavor (only used by profile client-coordinated).
#   eventual = CRDT bulk store + Raft strong keyspaces ; strong = Raft store
CLIENT_CONSISTENCY=eventual

# Replica counts for the SCALABLE services (the fixed Raft quorums ignore these).
SERVER_REPLICAS=3
CLIENT_REPLICAS=2

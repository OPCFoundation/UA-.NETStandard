<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <AssemblyName>$(AssemblyPrefix).SourceGeneration.Stack</AssemblyName>
    <RootNamespace>Opc.Ua.SourceGeneration</RootNamespace>
    <Description>OPC UA source generation Library</Description>
    <!-- Suppress CS8002: SourceGenerator.Foundations.Contracts is not strong-named.
         Source generators are packaged as analyzers and not referenced at runtime. -->
    <NoWarn>$(NoWarn);CS8002</NoWarn>
  </PropertyGroup>
  <!-- Package as source generator -->
  <PropertyGroup>
    <PackageId>$(PackagePrefix).Opc.Ua.SourceGeneration.Stack</PackageId>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>NugetREADME.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageLicenseFile></PackageLicenseFile>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <NoPackageAnalysis>true</NoPackageAnalysis>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageId>$(PackageId).Debug</PackageId>
  </PropertyGroup>
  <PropertyGroup>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <AssemblySearchPath_UseOutDir>true</AssemblySearchPath_UseOutDir>
    <SgfAddModuleInitializerAttribute>false</SgfAddModuleInitializerAttribute>
  </PropertyGroup>
  <ItemGroup>
    <CompilerVisibleProperty Include="SgfAddModuleInitializerAttribute" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Opc.Ua.SourceGeneration.Stack.Tests"/>
  </ItemGroup>
  <ItemGroup>
    <!-- Keep Roslyn compile assets transitive for project-reference test consumers.
         SourceGeneratorPackaging.targets suppresses package dependencies and host DLL payloads. -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
    <PackageReference Include="SourceGenerator.Foundations" >
      <!-- Make private asset because assembly name comparer symbol conflict in test -->
      <PrivateAssets>all</PrivateAssets>
      <OutputItemType>Analyzer</OutputItemType>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Update="NETStandard.Library" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Opc.Ua.SourceGeneration.Core\Opc.Ua.SourceGeneration.Core.csproj">
      <PrivateAssets>all</PrivateAssets>
    </ProjectReference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Opc.Ua.SourceGeneration\SourceGeneratorTelemetry.cs" />
    <Compile Include="..\Opc.Ua.SourceGeneration\CompilationOptions.cs" />
    <Compile Include="..\Opc.Ua.SourceGeneration\Extensions.cs" />
  </ItemGroup>
  <ItemGroup>
    <None Include="NugetREADME.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <Import Project="..\Opc.Ua.SourceGeneration\SourceGeneratorPackaging.targets" />
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks Condition="'$(CustomTestTarget)' == ''">net8.0;net9.0;net10.0</TargetFrameworks>
    <TargetFrameworks Condition="'$(CustomTestTarget)' == 'net8.0' OR '$(CustomTestTarget)' == 'net9.0' OR '$(CustomTestTarget)' == 'net10.0'">$(CustomTestTarget)</TargetFrameworks>
    <TargetFrameworks Condition="'$(TargetFrameworks)' == ''">$(CustomTestTarget)</TargetFrameworks>
    <AssemblyName>Opc.Ua.PubSub.Fuzz</AssemblyName>
    <RootNamespace>PubSub.Fuzz</RootNamespace>
  </PropertyGroup>
  <PropertyGroup Condition="'$(LibFuzzer)' == 'true'">
    <DefineConstants>$(DefineConstants);LIBFUZZER</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\Common\Fuzz\Program.cs" Link="Program.cs" />
    <Compile Include="..\Common\Fuzz\FuzzMethods.cs" Link="FuzzMethods.cs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="SharpFuzz" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Opc.Ua.PubSub\Opc.Ua.PubSub.csproj" />
  </ItemGroup>
</Project>

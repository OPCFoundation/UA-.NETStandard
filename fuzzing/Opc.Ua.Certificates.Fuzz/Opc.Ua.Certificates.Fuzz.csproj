<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>$(AppTargetFramework)</TargetFramework>
    <AssemblyName>Opc.Ua.Certificates.Fuzz</AssemblyName>
    <RootNamespace>Certificates.Fuzz</RootNamespace>
  </PropertyGroup>
  <PropertyGroup Condition="'$(LibFuzzer)' == 'true'">
    <DefineConstants>$(DefineConstants);LIBFUZZER</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\Common\Fuzz\Program.cs" Link="Program.cs" />
    <Compile Include="..\Common\Fuzz\FuzzMethods.cs" Link="FuzzMethods.cs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="SharpFuzz" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Opc.Ua.Core\Opc.Ua.Core.csproj" />
    <ProjectReference Include="..\..\src\Opc.Ua.Security.Certificates\Opc.Ua.Security.Certificates.csproj" />
  </ItemGroup>
</Project>
